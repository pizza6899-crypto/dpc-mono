{
  "name": "dpc-mono",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "api:dev": "pnpm -F api dev",
    "api:build": "pnpm -F api build",
    "api:start": "pnpm -F api start",
    "api:test": "pnpm -F api test",
    "api:test:dev": "pnpm -F api test:dev",
    "api:lint": "pnpm -F api lint",
    "api:format": "pnpm -F api format",
    "api:cli": "pnpm -F api cli",
    "api:zip": "pnpm -F api zip",
    "api:template": "pnpm -F api template:generate",
    "db:generate": "pnpm -F api db:generate",
    "db:migrate": "pnpm -F api db:migrate",
    "db:format": "pnpm -F api format",
    "db:reset": "pnpm -F api db:migrate reset",
    "db:deploy": "pnpm -F api db:migrate deploy",
    "db:push": "pnpm -F api db:push",
    "db:seed": "pnpm -F api db:seed",
    "db:studio": "pnpm -F api db:studio",
    "shared:build": "pnpm -F @repo/shared build",
    "shared:dev": "pnpm -F @repo/shared dev",
    "zip": "node scripts/package-for-deploy.js && open .",
    "swagger": "pnpm -F api swagger && pnpm -F admin orval",
    "docker:build": "node scripts/docker-build.js",
    "docker:save": "pnpm docker:build && echo '💾 Saving image to dpc-api.tar...' && docker save dpc-api:latest -o dpc-api.tar && echo '✅ Saved to dpc-api.tar' && open .",
    "docker:run": "docker run --rm --env-file .env.local -p 3001:3001 dpc-api:latest",
    "docker:push-ecr": "pnpm -F api docker:tag-ecr && pnpm -F api docker:build && pnpm -F api docker:push",
    "docker:clean": "docker system prune -f"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "dotenv-cli": "^11.0.0",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3"
    }
  }
}