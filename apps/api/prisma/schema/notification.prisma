model Alert {
  id             BigInt
  event          String
  userId         BigInt?           @map("user_id")
  targetGroup    String?           @map("target_group")
  payload        Json
  idempotencyKey String?           @map("idempotency_key")
  status         AlertStatus       @default(PENDING)
  channels       ChannelType[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  notifications  NotificationLog[]
  user           User?             @relation(fields: [userId], references: [id])

  @@id([createdAt, id])
  @@index([idempotencyKey, createdAt(sort: Desc)])
  @@index([userId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([event, createdAt])
  @@map("alerts")
}

// 알림 템플릿 정의 (메타데이터만 관리, 실제 내용은 Translation에서)
model NotificationTemplate {
  id BigInt @id @default(autoincrement())

  // 템플릿 식별 (관리자용)
  name        String // 관리자용 이름
  description String? // 템플릿 설명

  // 이벤트 연결
  event   String // Alert.event와 매핑
  channel ChannelType // EMAIL, SMS, IN_APP

  // 메타데이터
  variables Json @default("[]") // 필요한 변수 목록 정의 ["userName", "amount"]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notifications NotificationLog[]
  translations  NotificationTemplateTranslation[]

  @@unique([event, channel]) // 같은 이벤트+채널 조합은 하나만
  @@map("notification_templates")
}

// 템플릿 다국어 지원
model NotificationTemplateTranslation {
  id         BigInt   @id @default(autoincrement())
  templateId BigInt   @map("template_id")
  locale     Language

  titleTemplate     String  @map("title_template")
  bodyTemplate      String  @map("body_template")
  actionUriTemplate String? @map("action_uri_template")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  template NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale]) // 같은 템플릿의 같은 언어는 하나만
  @@index([locale])
  @@map("notification_template_translations")
}

model NotificationLog {
  id             BigInt
  alertId        BigInt   @map("alert_id")
  alertCreatedAt DateTime @map("alert_created_at")

  // 템플릿 참조
  templateId    BigInt?   @map("template_id") // 사용된 템플릿
  templateEvent String?   @map("template_event") // 스냅샷 (템플릿 삭제/변경 대비)
  locale        Language? // 렌더링에 사용된 언어

  channel    ChannelType
  receiverId BigInt      @map("receiver_id")
  target     String?

  // 렌더링된 최종 결과
  title     String?
  body      String?
  actionUri String? @map("action_uri")

  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  priority     Int          @default(3) // 낮을수록 우선순위가 높음
  scheduledAt  DateTime     @default(now()) @map("scheduled_at")
  status       NotifyStatus @default(PENDING)
  errorMessage String?      @map("error_message")
  sentAt       DateTime?    @map("sent_at")
  retryCount   Int          @default(0) @map("retry_count")
  metadata     Json?        @default("{}") @map("metadata")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  alert    Alert                 @relation(fields: [alertCreatedAt, alertId], references: [createdAt, id])
  receiver User                  @relation(fields: [receiverId], references: [id])
  template NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@id([createdAt, id])
  @@index([createdAt, alertId])
  @@index([receiverId, channel, isDeleted, id(sort: Desc)])
  @@index([receiverId, channel, isRead, createdAt])
  @@index([status, scheduledAt, priority])
  @@index([templateId])
  @@map("notification_logs")
}

enum AlertStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotifyStatus {
  PENDING
  SENDING
  SUCCESS
  FAILED
  CANCELED
}

enum ChannelType {
  EMAIL
  SMS
  IN_APP
  WEBSOCKET
  TELEGRAM
}
