/// [Gamification] 시스템 전역 정책 설정
/// 
/// 게이미피케이션 엔진의 밸런스와 비용 정책을 한곳에서 관리합니다.
model GamificationConfig {
  id Int @id @default(1) // 싱글톤으로 관리

  // [XP Policy]
  // 1 USD 베팅(Rolling)당 획득할 경험치 배율
  // 📝 계산식: 획득 XP = (베팅 USD 금액) * xp_grant_multiplier_usd
  xpGrantMultiplierUsd Decimal @default(1.0) @map("xp_grant_multiplier_usd") @db.Decimal(32, 18)

  // [Stat Policy]
  // 레벨업당 지급되는 기본 스텟 포인트
  statPointsGrantPerLevel Int @default(1) @map("stat_points_grant_per_level")
  // 한 스텟에 투자할 수 있는 최대 수량 (상한선)
  maxStatLimit            Int @default(999) @map("max_stat_limit")

  // [Reset Policy]
  // 스텟 초기화 통화별 고정 가격표
  // 📝 데이터 예시: { "KRW": 10000, "USD": 10, "JPY": 1500 }
  statResetPrices Json @default("{}") @map("stat_reset_prices")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gamification_configs")
}

/// [Gamification] 레벨 정의 마스터 데이터
/// 
model LevelDefinition {
  level Int @id // 레벨 그 자체가 PK

  // [승급 요건]
  requiredXp Decimal @map("required_xp") @db.Decimal(32, 18)

  // [UI용 티어 보상] (Enum으로 타입 안정성 확보)
  tierCode     TierCode @default(WHITE) @map("tier_code")
  tierImageUrl String?  @map("tier_image_url") // 티어 뱃지 이미지 URL

  // [기본 보상]
  statPointsBoost Int @default(1) @map("stat_points_boost")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("level_definitions")
}

/// [Gamification] 아이템 카테고리 정보
model ItemCatalog {
  id   BigInt   @id @default(autoincrement())
  code String   @unique // 시스템 내부 식별자 (예: "SWORD_001")
  type ItemType

  // 아이템의 효과 상세 정의 (EffectType 기반 JSON 구조)
  effects Json @map("effects")

  // 아이템 만료/소모 정책
  expiryType    ExpiryType @default(PERMANENT) @map("expiry_type")
  // 총 사용 가능한 횟수 (null = 무제한, ExpiryType이 PERMANENT가 아닐 때 필수)
  maxUsageCount Int?       @map("max_usage_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations    ItemTranslation[]
  userInventories UserInventory[]
  inventoryLogs   UserInventoryLog[]

  @@map("item_catalogs")
}

enum ExpiryType {
  PERMANENT // 영구 아이템 (기본값)
  // USAGE_COUNT // 총 사용 횟수 제한 (소모품 등)
  // DAILY_AUTOMATIC // 총 사용 회수가 있으나, 매일 1회 자동으로만 소모
}

/// [Gamification] 아이템 다국어 번역 정보
model ItemTranslation {
  id       BigInt   @id @default(autoincrement())
  itemId   BigInt   @map("item_id")
  language Language // 시스템 표준 언어 Enum 사용

  name        String
  description String?

  item ItemCatalog @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, language])
  @@index([language])
  @@map("item_translations")
}

enum ItemType {
  ARTIFACT // 특별한 효과를 지닌 수집/장착형 유물
}

/// [Gamification] 아이템 및 스탯이 가질 수 있는 효과 유형
enum EffectType {
  STAT_BOOST // 특정 스탯(카지노 혜택, 잭팟 등) 수치 가산
}

/// [Gamification] 레벨 구간별 UI용 티어 분류 (순수 시각적 보상용)
enum TierCode {
  WHITE
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  VIP
}
