/// 유저 전역(Global) 통합 분석 지표 (USD 환산 기준)
/// 
/// 유저의 평생 가치(LTV, GGR 등)를 평가하고 랭킹을 산정하는 단일 로우 테이블
/// 모든 화폐(Currency) 지갑에서 발생한 내역을 USD 단위로 통합하여 기록합니다.
model UserGlobalTotalStats {
    userId BigInt @id @map("user_id")

    // --- 핵심 비즈니스 KPI ---
    // LTV (Lifetime Value) = 총 입금액(USD) - 총 출금액(USD)
    ltvUsd Decimal @default(0) @map("ltv_usd") @db.Decimal(32, 18)

    // GGR (Gross Gaming Revenue) = 총 베팅액(USD) - 총 승리액(USD)
    ggrUsd Decimal @default(0) @map("ggr_usd") @db.Decimal(32, 18)

    // NGR (Net Gaming Revenue) = GGR - 지급된 프로모션(보너스, 콤프) 비용(USD)
    ngrUsd Decimal @default(0) @map("ngr_usd") @db.Decimal(32, 18)

    // --- 집계 누적 필드 (Raw Data) ---
    totalDepositUsd  Decimal @default(0) @map("total_deposit_usd") @db.Decimal(32, 18)
    totalWithdrawUsd Decimal @default(0) @map("total_withdraw_usd") @db.Decimal(32, 18)
    totalBetUsd      Decimal @default(0) @map("total_bet_usd") @db.Decimal(32, 18)
    totalWinUsd      Decimal @default(0) @map("total_win_usd") @db.Decimal(32, 18)
    totalPromoUsd    Decimal @default(0) @map("total_promo_usd") @db.Decimal(32, 18) // 보너스+콤프+캐시백 합산

    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id])

    // LTV 및 GGR 기준 랭킹 조회를 위한 B-Tree 인덱스
    @@index([ltvUsd(sort: Desc)])
    @@index([ggrUsd(sort: Desc)])
    @@index([ngrUsd(sort: Desc)])
    @@map("user_global_total_stats")
}

/// 유저 시간별(Hourly) 전역 통합 지표 (USD 환산 기준)
/// 타임존별 일간/주간/월간 집계의 원천 데이터로 사용됩니다.
model UserGlobalHourlyStats {
    userId BigInt   @map("user_id")
    hour   DateTime @map("hour") @db.Timestamp(3) // UTC 기준 정시 (ex: 2024-03-03 14:00:00)

    ltvUsd Decimal @default(0) @map("ltv_usd") @db.Decimal(32, 18)
    ggrUsd Decimal @default(0) @map("ggr_usd") @db.Decimal(32, 18)
    ngrUsd Decimal @default(0) @map("ngr_usd") @db.Decimal(32, 18)

    hourlyDepositUsd  Decimal @default(0) @map("hourly_deposit_usd") @db.Decimal(32, 18)
    hourlyWithdrawUsd Decimal @default(0) @map("hourly_withdraw_usd") @db.Decimal(32, 18)
    hourlyBetUsd      Decimal @default(0) @map("hourly_bet_usd") @db.Decimal(32, 18)
    hourlyWinUsd      Decimal @default(0) @map("hourly_win_usd") @db.Decimal(32, 18)
    hourlyPromoUsd    Decimal @default(0) @map("hourly_promo_usd") @db.Decimal(32, 18)

    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id])

    @@id([hour, userId])
    @@index([hour, ggrUsd(sort: Desc)])
    @@index([hour, ltvUsd(sort: Desc)])
    @@index([hour, ngrUsd(sort: Desc)])
    @@map("user_global_hourly_stats")
}
