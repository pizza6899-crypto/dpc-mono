/**
 * Analytics Schema
 * 데이터 분석 및 통계를 위한 스키마
 */

/**
 * 사용자 시간별 통계
 * 사용자의 시간별 활동 및 잔액 변화를 추적합니다.
 * 리얼타임 차트 및 통계 제공을 위해 트랜잭션 발생 시 실시간으로 업데이트되거나,
 * 배치 작업을 통해 집계될 수 있습니다.
 */
model UserHourlyStat {
  // Partitioning Note:
  // PostgreSQL pg_partman 사용을 고려하여 id(Autoincrement)를 제거하고
  // date가 포함된 복합키를 PK로 사용합니다. (PK는 반드시 파티션 키를 포함해야 함)
  // Partition Key: date (Range Partitioning)

  userId   BigInt               @map("user_id")
  currency ExchangeCurrencyCode
  date     DateTime // YYYY-MM-DD HH:00:00 (시간 단위)

  // --- 트랜잭션 집계 ---
  totalDeposit  Decimal @default(0) @map("total_deposit") @db.Decimal(32, 18)
  totalWithdraw Decimal @default(0) @map("total_withdraw") @db.Decimal(32, 18)
  depositCount  Int     @default(0) @map("deposit_count")
  withdrawCount Int     @default(0) @map("withdraw_count")

  // --- 보너스 집계 ---
  totalBonusGiven     Decimal @default(0) @map("total_bonus_given") @db.Decimal(32, 18) // 지급된 보너스 총액
  totalBonusUsed      Decimal @default(0) @map("total_bonus_used") @db.Decimal(32, 18) // 배팅에 사용된 보너스 총액
  totalBonusConverted Decimal @default(0) @map("total_bonus_converted") @db.Decimal(32, 18) // 롤링 완료 후 현금으로 전환된 총액

  // --- 게임 활동 집계 (전체) ---
  totalBet       Decimal @default(0) @map("total_bet") @db.Decimal(32, 18)
  totalWin       Decimal @default(0) @map("total_win") @db.Decimal(32, 18)
  netWin         Decimal @default(0) @map("net_win") @db.Decimal(32, 18) // 유저 순수익 (Win - Bet)
  ggr            Decimal @default(0) @map("ggr") @db.Decimal(32, 18) // 운영 수익 (Gross Gaming Revenue = Bet - Win)
  totalGameCount Int     @default(0) @map("total_game_count")

  // --- 게임 카테고리별 상세 집계 ---
  // 슬롯 (Slots)
  slotBetAmount Decimal @default(0) @map("slot_bet_amount") @db.Decimal(32, 18)
  slotWinAmount Decimal @default(0) @map("slot_win_amount") @db.Decimal(32, 18)
  slotGgr       Decimal @default(0) @map("slot_ggr") @db.Decimal(32, 18) // 슬롯 GGR
  slotGameCount Int     @default(0) @map("slot_game_count")

  // 라이브 카지노 (Live Casino)
  liveBetAmount Decimal @default(0) @map("live_bet_amount") @db.Decimal(32, 18)
  liveWinAmount Decimal @default(0) @map("live_win_amount") @db.Decimal(32, 18)
  liveGgr       Decimal @default(0) @map("live_ggr") @db.Decimal(32, 18) // 라이브 GGR
  liveGameCount Int     @default(0) @map("live_game_count")

  // --- 콤프/포인트 집계 ---
  totalCompEarned    Decimal @default(0) @map("total_comp_earned") @db.Decimal(32, 18)
  totalCompConverted Decimal @default(0) @map("total_comp_converted") @db.Decimal(32, 18)
  totalCompDeducted  Decimal @default(0) @map("total_comp_deducted") @db.Decimal(32, 18)

  // --- 잔액 스냅샷 (현금) ---
  // 그 시간의 시작 잔액
  startBalance Decimal @default(0) @map("start_balance") @db.Decimal(32, 18)
  // 그 시간의 마감 잔액
  endBalance   Decimal @default(0) @map("end_balance") @db.Decimal(32, 18)

  // --- 잔액 스냅샷 (보너스) ---
  // 그 시간의 시작 보너스 잔액
  startBonusBalance Decimal @default(0) @map("start_bonus_balance") @db.Decimal(32, 18)
  // 그 시간의 마감 보너스 잔액
  endBonusBalance   Decimal @default(0) @map("end_bonus_balance") @db.Decimal(32, 18)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Partitioning: PK must include the partition key (date)
  @@id([userId, date, currency])
  // Indexes for Analytics
  @@index([date]) // 전체 유저 기간별 조회 (시간별 총계 등)
  @@index([userId, date]) // 특정 유저 기간별 조회 (마이페이지 리포트 등)
  @@map("user_hourly_stats")
}
