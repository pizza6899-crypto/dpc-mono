// 1. 관리자 수동 조작 상세
model AdminAdjustmentDetail {
  id           BigInt               @id @default(autoincrement())
  adminUserId  BigInt               @map("admin_user_id") // 조작한 관리자 ID
  reasonCode   AdjustmentReasonCode @map("reason_code") // 사유 코드 (CS_ERROR, PROMOTION_WIN 등)
  internalNote String?              @map("internal_note") // 상세 메모
  adminUser    User                 @relation("AdminAdjustments", fields: [adminUserId], references: [id])

  @@map("admin_adjustment_details")
}

// 2. 시스템 자동 처리 상세
model SystemAdjustmentDetail {
  id          BigInt  @id @default(autoincrement())
  serviceName String  @map("service_name") // 처리 주체 (REWARD_ENGINE, ROLLBACK_WORKER 등)
  triggerId   String? @map("trigger_id") // 원인이 된 이벤트 ID나 배치 작업 ID
  actionName  String  @map("action_name") // 구체적 액션 (DAILY_CHECKIN, TOURNAMENT_PRIZE)
  metadata    Json? // 당시 시스템 상태값 스냅샷

  @@index([serviceName, actionName])
  @@map("system_adjustment_details")
}

enum AdjustmentReasonCode {
  CS_RECOVERY // CS 대응 및 복구
  PROMOTION_REWARD // 프로모션/이벤트 보상
  SYSTEM_ERROR_FIX // 시스템 오류 수정
  MANUAL_DEPOSIT // 수동 입금 처리
  TEST_ACCOUNT // 테스트 계정 자산 지급
  OTHER // 기타 (기타 선택 시 메모 필수)
}
