enum FileStatus {
  PENDING
  ACTIVE
  DELETED
}

enum FileAccessType {
  PUBLIC // 누구나 접근 가능 (CDN/S3 Public URL)
  PRIVATE // 인증된 사용자만 접근 가능 (Presigned URL 필요)
}

model File {
  id BigInt @id @default(autoincrement())

  // 스토리지 정보
  bucket String
  path   String  @map("path")
  key    String  @unique
  hash   String? // 파일 무결성 확인 및 중복 방지 (MD5/SHA256)

  // 메타데이터
  filename String
  mimetype String
  size     BigInt
  width    Int?
  height   Int?

  // 관리 정보
  status     FileStatus     @map("status")
  accessType FileAccessType @map("access_type")

  // 업로드한 주체
  uploaderId BigInt? @map("uploader_id")
  // User 모델이 있는 파일(common.prisma)에 "files Relation"이 정의되면 주석 해제
  // uploader   User?    @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  // 파일 사용처 관계
  usages FileUsage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([path])
  @@index([uploaderId])
  @@index([status])
  @@map("files")
}

model FileUsage {
  id     BigInt @id @default(autoincrement())
  fileId BigInt @map("file_id")
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // 폴리모픽 참조 필드
  usageType String @map("usage_type")
  usageId   BigInt @map("usage_id")

  // 노출 순서
  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([usageType, usageId, fileId])
  @@index([usageType, usageId])
  @@map("file_usages")
}
