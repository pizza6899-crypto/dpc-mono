enum TransactionType {
  DEPOSIT
  WITHDRAW
  GAME
  BONUS
  COMP_CLAIM
  SYSTEM // 시스템 자동 지급/차감 (이벤트 등)
  ADMIN_ADJUST // 관리자가 어드민 패널에서 수동으로 지급/차감
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum GameReplayType {
  TEXT
  URL
  HTML
}

enum BetType {
  NORMAL
  TIP
}

enum WinType {
  NORMAL
  JACKPOT
}

enum BonusType {
  PROMOTION
  JACKPOT
  IN_GAME_BONUS
}

enum WithdrawDetailStatus {
  PENDING
  PROCESSING
  SENDING
  COMPLETED
  FAILED
  CANCELLED
  REJECTED
}

enum ExchangeRateProvider {
  NOWPAYMENT
  COINGECKO
  OPEN_EXCHANGE_RATES
}

enum TokenType {
  PASSWORD_RESET
}

enum LoginAttemptResult {
  SUCCESS
  FAILED
}

enum LoginFailureReason {
  INVALID_CREDENTIALS
  USER_NOT_FOUND
  ACCOUNT_SUSPENDED
  ACCOUNT_CLOSED
  THROTTLE_LIMIT_EXCEEDED
  UNKNOWN
}

model LoginAttempt {
  id                BigInt              @id @default(autoincrement())
  uid               String              @unique
  userId            BigInt?             @map("user_id")
  result            LoginAttemptResult
  failureReason     LoginFailureReason? @map("failure_reason")
  ipAddress         String?             @map("ip_address") @db.Inet
  userAgent         String?             @map("user_agent")
  deviceFingerprint String?             @map("device_fingerprint")
  isMobile          Boolean?            @map("is_mobile")
  attemptedAt       DateTime            @default(now()) @map("attempted_at")
  email             String?
  isAdmin           Boolean             @default(false) @map("is_admin")
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([attemptedAt])
  @@index([result])
  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
  @@map("login_attempts")
}

enum WalletBalanceType {
  CASH
  BONUS
  LOCK
  VAULT
}
