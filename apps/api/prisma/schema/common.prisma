generator client {
  provider        = "prisma-client-js"
  moduleFormat    = "cjs"
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

// Kysely 타입 생성기 - Prisma 스키마로부터 타입 안전한 SQL 쿼리를 위한 타입 생성
generator kysely {
  provider     = "prisma-kysely"
  output       = "../../src/generated/kysely"
  fileName     = "kysely-types.ts"
  enumFileName = "kysely-enums.ts"
}

datasource db {
  provider   = "postgresql"
  // [인프라 익스텐션 관리 정책]
  // pg_cron 등 인프라 레벨 익스텐션은 Shadow DB 생성 시 권한/설정 충돌(Drift)을 유발하므로 Prisma 관리에서 제외합니다.
  // 로컬: 필요 시 'pnpm db:infra' 수동 실행 (Drift 발생 시 Reset 수락 or db:push 사용)
  // 운영: 초기 구축 시 'pnpm db:infra' 1회 실행 후 'db:deploy'로 테이블 관리
  // 관리 제외 대상: pg_cron, pg_partman, pg_stat_statements, pg_repack
  extensions = [pg_trgm, unaccent, vector, pgcrypto, uuid_ossp(map: "uuid-ossp"), citext, btree_gist, tsm_system_rows, fuzzystrmatch]
}

model User {
  id                   BigInt                @id @default(autoincrement())
  whitecliffId         BigInt?               @unique @map("whitecliff_id")
  whitecliffSystemId   BigInt?               @unique @map("whitecliff_system_id")
  whitecliffUsername   String?               @unique @map("whitecliff_username")
  dcsId                String?               @unique @map("dcs_id")
  email                String?               @unique
  passwordHash         String?               @map("password_hash")
  socialType           SocialType?           @map("social_type")
  socialId             String?               @map("social_id")
  role                 UserRoleType          @default(USER)
  status               UserStatus            @default(ACTIVE)
  kycLevel             KycLevel              @default(NONE) @map("kyc_level")
  country              String?
  language             Language?
  timezone             String?
  timezoneOffset       Int?                  @map("timezone_offset")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  affiliateCodes       AffiliateCode[]       @relation("AffiliateCodes")
  affiliateCommissions AffiliateCommission[] @relation("AffiliateCommissions")
  subUserCommissions   AffiliateCommission[] @relation("SubUserCommissions")
  affiliateWallets     AffiliateWallet[]     @relation("AffiliateWallets")

  gameSessions           CasinoGameSession[]
  affiliateReferrals     Referral[]              @relation("AffiliateReferrals")
  referredUsers          Referral[]              @relation("ReferredUsers")
  depositDetails         DepositDetail[]
  withdrawalDetails      WithdrawalDetail[]
  userWallets            UserWallet[]
  userTotalStats         UserWalletTotalStats[]
  userHourlyStats        UserWalletHourlyStats[]
  userPromotions         UserPromotion[]
  userSessions           UserSession[]           @relation("UserSessions")
  revokedSessions        UserSession[]           @relation("RevokedSessions")
  verificationTokens     VerificationToken[]
  loginAttempts          LoginAttempt[]
  userTier               UserTier?
  tierHistory            TierHistory[]
  adminAdjustmentDetails AdminAdjustmentDetail[] @relation("AdminAdjustments")
  wageringRequirements   WageringRequirement[]
  compWallets            UserCompWallet[]
  compClaimHistories     CompClaimHistory[]
  alerts                 Alert[]
  notificationLogs       NotificationLog[]
  casinoGameRounds       CasinoGameRound[]
  tierConfigsUpdated     TierConfig[]            @relation("TierConfigUpdatedBy")
  tiersUpdated           Tier[]                  @relation("TierUpdatedBy")

  @@map("users")
}

enum SocialType {
  GOOGLE
  APPLE
  TELEGRAM
}

enum UserRoleType {
  USER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum Language {
  EN
  KO
  JA
}

enum KycLevel {
  NONE
  BASIC
  FULL
}
