generator client {
  provider      = "prisma-client-js"
  output        = "../../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

generator kysely {
  provider = "prisma-kysely"
  output   = "../../src/generated/kysely" // Kysely 타입 위치
  fileName = "types.ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     BigInt                  @id @default(autoincrement())
  whitecliffId           BigInt?                 @unique
  whitecliffSystemId     BigInt?                 @unique
  whitecliffUsername     String?                 @unique
  dcsId                  String?                 @unique
  email                  String?                 @unique
  passwordHash           String?
  socialType             SocialType?
  socialId               String?
  role                   UserRoleType            @default(USER)
  status                 UserStatus              @default(ACTIVE)
  kycLevel               KycLevel                @default(NONE)
  country                String?
  language               Language?
  timezone               String?
  timezoneOffset         Int?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  affiliateCodes         AffiliateCode[]         @relation("AffiliateCodes")
  affiliateCommissions   AffiliateCommission[]   @relation("AffiliateCommissions")
  subUserCommissions     AffiliateCommission[]   @relation("SubUserCommissions")
  affiliateWallets       AffiliateWallet[]       @relation("AffiliateWallets")
  EmailLog               EmailLog[]
  GameSession            CasinoGameSession[]
  affiliateReferrals     Referral[]              @relation("AffiliateReferrals")
  referredUsers          Referral[]              @relation("ReferredUsers")
  transactions           Transaction[]
  depositDetails         DepositDetail[]
  withdrawalDetails      WithdrawalDetail[]
  userWallets            UserWallet[]
  UserBalanceStats       UserBalanceStats[]
  UserPromotion          UserPromotion[]
  UserSession            UserSession[]           @relation("UserSessions")
  RevokedSessions        UserSession[]           @relation("RevokedSessions")
  UserToken              UserToken[]
  loginAttempts          LoginAttempt[]
  userTier               UserTier?
  tierHistory            TierHistory[]
  adminAdjustmentDetails AdminAdjustmentDetail[] @relation("AdminAdjustments")
  wageringRequirements   WageringRequirement[]
  hourlyStats            UserHourlyStat[]
  compWallets            UserCompWallet[]
  alerts                 Alert[]
  notificationLogs       NotificationLog[]
}

model UserWallet {
  userId               BigInt
  currency             ExchangeCurrencyCode
  mainBalance          Decimal               @default(0) @db.Decimal(32, 18)
  bonusBalance         Decimal               @default(0) @db.Decimal(32, 18)
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id])
  wageringRequirements WageringRequirement[]

  @@id([userId, currency])
  @@index([userId])
  @@index([currency])
  @@map("user_wallets")
}

model UserBalanceStats {
  userId                 BigInt
  currency               ExchangeCurrencyCode
  totalDeposit           Decimal              @default(0) @db.Decimal(32, 18)
  totalWithdraw          Decimal              @default(0) @db.Decimal(32, 18)
  totalBet               Decimal              @default(0) @db.Decimal(32, 18)
  totalWin               Decimal              @default(0) @db.Decimal(32, 18)
  totalBonus             Decimal              @default(0) @db.Decimal(32, 18)
  totalCompEarned        Decimal              @default(0) @db.Decimal(32, 18)
  totalCompUsed          Decimal              @default(0) @db.Decimal(32, 18)
  totalSettlementFromBet Decimal              @default(0) @db.Decimal(32, 18)
  totalSettlementFromVip Decimal              @default(0) @db.Decimal(32, 18)
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id])

  @@id([userId, currency])
  @@index([userId])
  @@index([currency])
}

model Transaction {
  id                     BigInt                     @id @default(autoincrement())
  userId                 BigInt
  type                   TransactionType
  status                 TransactionStatus
  currency               ExchangeCurrencyCode
  amount                 Decimal                    @db.Decimal(32, 18)
  beforeAmount           Decimal                    @db.Decimal(32, 18)
  afterAmount            Decimal                    @db.Decimal(32, 18)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  bonusDetail            BonusDetail?
  gameRound              GameRound?
  user                   User                       @relation(fields: [userId], references: [id])
  balanceDetails         TransactionBalanceDetail[]
  adminAdjustmentDetail  AdminAdjustmentDetail?
  systemAdjustmentDetail SystemAdjustmentDetail?

  compWalletTransactionId BigInt?                @map("comp_wallet_transaction_id")
  compWalletTransaction   CompWalletTransaction? @relation(fields: [compWalletTransactionId], references: [id])
  depositDetail           DepositDetail?
  withdrawalDetail        WithdrawalDetail?
}

model GameRound {
  id                             BigInt                @id @default(autoincrement())
  userId                         BigInt
  aggregatorType                 GameAggregatorType
  provider                       GameProvider
  aggregatorTxId                 String
  transactionId                  BigInt                @unique
  aggregatorGameId               Int
  totalBetAmountInGameCurrency   Decimal               @default(0) @db.Decimal(32, 18)
  totalWinAmountInGameCurrency   Decimal               @default(0) @db.Decimal(32, 18)
  netAmountInGameCurrency        Decimal               @default(0) @db.Decimal(32, 18)
  totalBetAmountInWalletCurrency Decimal               @default(0) @db.Decimal(32, 18)
  totalWinAmountInWalletCurrency Decimal               @default(0) @db.Decimal(32, 18)
  netAmountInWalletCurrency      Decimal               @default(0) @db.Decimal(32, 18)
  sessionId                      String?
  tableId                        String?
  roundId                        String?
  replayType                     GameReplayType?
  replayData                     String?
  totalPushAmount                Decimal?              @db.Decimal(32, 18)
  tieBetAmount                   Decimal?              @db.Decimal(32, 18)
  contributionAmount             Decimal?              @db.Decimal(32, 18)
  compEarned                     Decimal?              @db.Decimal(32, 18)
  jackpotContributionAmount      Decimal               @default(0) @db.Decimal(32, 18)
  startedAt                      DateTime?
  completedAt                    DateTime?
  gameId                         BigInt?
  gameSessionId                  BigInt
  AffiliateCommission            AffiliateCommission[]
  bets                           GameBet[]
  casinoGame                     CasinoGame?           @relation(fields: [gameId], references: [id])
  GameSession                    CasinoGameSession     @relation(fields: [gameSessionId], references: [id])
  transaction                    Transaction           @relation(fields: [transactionId], references: [id])
  wins                           GameWin[]

  @@unique([aggregatorTxId, aggregatorType])
}

model TransactionBalanceDetail {
  id                 BigInt      @id @default(autoincrement())
  transactionId      BigInt
  mainBalanceChange  Decimal?    @db.Decimal(32, 18)
  mainBeforeAmount   Decimal?    @db.Decimal(32, 18)
  mainAfterAmount    Decimal?    @db.Decimal(32, 18)
  bonusBalanceChange Decimal?    @db.Decimal(32, 18)
  bonusBeforeAmount  Decimal?    @db.Decimal(32, 18)
  bonusAfterAmount   Decimal?    @db.Decimal(32, 18)
  createdAt          DateTime    @default(now())
  transaction        Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

model BonusDetail {
  id                      BigInt             @id @default(autoincrement())
  createdAt               DateTime           @default(now())
  transactionTime         DateTime
  aggregatorType          GameAggregatorType
  provider                GameProvider
  bonusType               BonusType
  amount                  Decimal            @db.Decimal(32, 18)
  aggregatorPromotionId   String?
  aggregatorRoundId       String?
  aggregatorWagerId       String?
  aggregatorTransactionId String?
  aggregatorFreespinId    String?
  aggregatorSessionId     String?
  isEndRound              Boolean?
  description             String?
  gameId                  BigInt?
  transactionId           BigInt             @unique
  casinoGame              CasinoGame?        @relation(fields: [gameId], references: [id])
  transaction             Transaction        @relation(fields: [transactionId], references: [id])
}

model NowPaymentCallbackLog {
  id              BigInt    @id @default(autoincrement())
  requestHeaders  Json?
  requestBody     Json
  responseStatus  Int?
  responseBody    Json?
  processed       Boolean   @default(false)
  processingError String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
}

model ExchangeRate {
  id            Int                  @id @default(autoincrement())
  baseCurrency  ExchangeCurrencyCode
  quoteCurrency ExchangeCurrencyCode
  rate          Decimal              @db.Decimal(32, 18)
  provider      ExchangeRateProvider
  collectedAt   DateTime             @default(now())
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  previousRate  Decimal?             @db.Decimal(32, 18)
  changeRate    Decimal?             @db.Decimal(8, 4)
  isValid       Boolean              @default(true)

  @@unique([baseCurrency, quoteCurrency, provider])
  @@index([baseCurrency, quoteCurrency])
  @@index([baseCurrency, quoteCurrency, provider])
  @@index([collectedAt])
  @@index([isActive, collectedAt])
}

model UserToken {
  id        Int       @id @default(autoincrement())
  userId    BigInt
  type      TokenType
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([type, expiresAt])
  @@index([userId, type, usedAt])
  @@index([expiresAt])
}

model EmailLog {
  id        Int         @id @default(autoincrement())
  userId    BigInt?
  type      EmailType
  status    EmailStatus
  to        String
  subject   String
  from      String?
  messageId String?
  error     String?
  metadata  Json?       @default("{}")
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId, type, createdAt])
  @@index([to, type, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
}

enum SocialType {
  GOOGLE
  APPLE
  TELEGRAM
}

enum UserRoleType {
  USER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ExchangeCurrencyCode {
  USDT
  USD
  KRW
  JPY
  PHP
  IDR
  VND
  BTC
  ETH
  SOL
  XRP
  DOGE
  LTC
  BCH
  EOS
  TRX
}

enum Language {
  EN
  KO
  JA
}

enum KycLevel {
  NONE
  BASIC
  FULL
}

enum GameAggregatorType {
  WHITECLIFF
  DCS
}

enum GameCategory {
  LIVE_CASINO
  SLOTS
}

enum GameProvider {
  EVOLUTION
  PRAGMATIC_PLAY_LIVE
  PG_SOFT
  PRAGMATIC_PLAY_SLOTS
  RELAX_GAMING
  PLAYNGO
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  GAME
  BONUS
  COMP_CLAIM
  SYSTEM // 시스템 자동 지급/차감 (이벤트 등)
  ADMIN_ADJUST // 관리자가 어드민 패널에서 수동으로 지급/차감
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum GameReplayType {
  TEXT
  URL
  HTML
}

enum BetType {
  NORMAL
  TIP
}

enum WinType {
  NORMAL
  JACKPOT
}

enum BonusType {
  PROMOTION
  JACKPOT
  IN_GAME_BONUS
}

enum WithdrawDetailStatus {
  PENDING
  PROCESSING
  SENDING
  COMPLETED
  FAILED
  CANCELLED
  REJECTED
}

enum ExchangeRateProvider {
  NOWPAYMENT
  COINGECKO
  OPEN_EXCHANGE_RATES
}

enum TokenType {
  PASSWORD_RESET
}

enum EmailType {
  PASSWORD_RESET
}

enum EmailStatus {
  SENT
  FAILED
}

enum LoginAttemptResult {
  SUCCESS
  FAILED
}

enum LoginFailureReason {
  INVALID_CREDENTIALS
  USER_NOT_FOUND
  ACCOUNT_SUSPENDED
  ACCOUNT_CLOSED
  THROTTLE_LIMIT_EXCEEDED
  UNKNOWN
}

model LoginAttempt {
  id                BigInt              @id @default(autoincrement())
  uid               String              @unique
  userId            BigInt?
  result            LoginAttemptResult
  failureReason     LoginFailureReason?
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  isMobile          Boolean?
  attemptedAt       DateTime            @default(now())
  email             String?
  isAdmin           Boolean             @default(false)
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([attemptedAt])
  @@index([result])
  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
}
