model CompConfig {
  id       BigInt               @id @default(autoincrement())
  currency ExchangeCurrencyCode // 통화별 고유 설정

  // 시스템 스위치
  isEarnEnabled       Boolean @map("is_earn_enabled") // 적립 가능 여부
  isSettlementEnabled Boolean @default(true) @map("is_settlement_enabled") // 매일 새벽 자동 정산(Reward 전환) 활성화 여부

  // 정책 설정
  maxDailyEarnPerUser Decimal @map("max_daily_earn_per_user") @db.Decimal(32, 18) // 유저당 일일 최대 적립 한도 (0=무제한)
  minSettlementAmount Decimal @default(0) @map("min_settlement_amount") @db.Decimal(32, 18) // 최소 정산 금액 필드

  description String? // 관리자 메모

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([currency])
  @@map("comp_configs")
}

model UserCompAccount {
  id       BigInt               @id @default(autoincrement())
  userId   BigInt               @map("user_id")
  currency ExchangeCurrencyCode

  totalEarned Decimal @default(0) @map("total_earned") @db.Decimal(32, 18) // 평생 획득량 (롤백 대응)
  totalUsed   Decimal @default(0) @map("total_used") @db.Decimal(32, 18) // 평생 정산 처리된 금액

  isFrozen Boolean @default(false) @map("is_frozen") // 해당 통화 콤프 적립/정산 동결 여부

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  transactions CompAccountTransaction[]
  user         User                     @relation(fields: [userId], references: [id])

  @@unique([userId, currency])
  @@index([isFrozen])
  @@map("user_comp_accounts")
}

model CompDailySettlement {
  id       BigInt               @id @default(autoincrement())
  userId   BigInt               @map("user_id")
  currency ExchangeCurrencyCode

  // 기준 일자 (DB 순수 Date 타입)
  date DateTime @db.Date

  // 해당 일자에 누적된 콤프량
  totalEarned Decimal @default(0) @map("total_earned") @db.Decimal(32, 18)

  // 정산 상태
  status CompSettlementStatus @default(UNSETTLED)

  // 정산 성공 시 발급된 Reward ID (추적용)
  rewardId BigInt? @map("reward_id")

  // 정산 실패 시 사유
  failureReason String? @map("failure_reason")

  processedAt DateTime? @map("processed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  // 한 유저당 날짜/통화별 원장은 딱 1개
  @@unique([userId, currency, date])
  // 정산 잡 처리를 위한 인덱스
  @@index([status, date])
  // 유저별 정산 내역 조회를 위한 인덱스
  @@index([userId, status])
  @@map("comp_daily_settlements")
}

enum CompSettlementStatus {
  UNSETTLED // 정산 대기
  SETTLED // 정산 완료
  FAILED // 정산 실패
  SKIPPED // 정산 스킵 (최소 금액 미달 등)
}

model CompAccountTransaction {
  id            BigInt              @map("id") // Snowflake ID 적용 (PK)
  compAccountId BigInt              @map("comp_account_id") // 어느 계정의 거래인가
  amount        Decimal             @db.Decimal(32, 18) // 변경 금액 (양수: 획득, 음수: 사용/차감)
  appliedRate   Decimal?            @map("applied_rate") @db.Decimal(8, 4) // 당시 적용된 요율 스냅샷
  type          CompTransactionType // EARN(적립), SETTLEMENT(자동 정산), ADMIN(관리자), ROLLBACK(회수)

  referenceId         BigInt? @map("reference_id") // 예: gameRoundId, paymentId
  processedBy         BigInt? @map("processed_by") // 처리한 관리자 ID (ADMIN 등의 경우 필수)
  parentTransactionId BigInt? @map("parent_transaction_id") // ROLLBACK 시 원본 트랜잭션 ID 참조
  metadata            Json?   @map("metadata")
  description         String? // 비고

  createdAt DateTime @map("created_at")

  account UserCompAccount @relation(fields: [compAccountId], references: [id])

  @@id([id, createdAt])
  @@unique([type, referenceId]) // 중복 적립 방지 (동일 건에 대한 중복 처리 방지)
  @@index([compAccountId])
  @@index([createdAt])
  @@index([parentTransactionId]) // 롤백 추적 쿼리 성능용
  @@map("comp_account_transactions")
}

enum CompTransactionType {
  EARN
  SETTLEMENT
  ADMIN
  ROLLBACK
}
