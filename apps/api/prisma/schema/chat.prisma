/**
 * rest api + socket.io로 처리.
 * 구현해야하는 기능
 * 1. 고객응대 (SUPPORT 1:1)
 * 2. 글로벌챗팅 (PUBLIC)
 * 3. 챗팅방 기준 챗팅 (언어별, 국가별, 게임카테고리별 등 metadata 활용)
 * [특이사항]
 * - 히스토리: REST API
 * - 송신: REST API
 * - 수신: Socket.io
 * - 게이트웨이 분리: Admin(상담원), User/Guest(고객)
 */

/// 채팅 시스템 글로벌 설정
model ChatConfig {
    id Int @id @default(1)

    /// 글로벌 채팅 활성화 여부
    isGlobalChatEnabled Boolean @default(true) @map("is_global_chat_enabled")

    /// 채팅 메시지 최대 길이
    maxMessageLength Int @default(500) @map("max_message_length")

    /// 도배 방지 쿨다운 (초)
    defaultSlowModeSeconds Int @default(3) @map("default_slow_mode_seconds")

    /// 채팅 참여를 위한 최소 티어 레벨
    minChatTierLevel Int @default(0) @map("min_chat_tier_level")

    /// 중복 메시지 차단 여부
    blockDuplicateMessages Boolean @default(true) @map("block_duplicate_messages")

    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("chat_configs")
}

model ChatRoom {
    id   BigInt       @id @default(autoincrement())
    type ChatRoomType @default(PUBLIC)

    isActive Boolean @default(true) @map("is_active")

    // [Criteria] 언어, 국가, 게임 카테고리 등 동적 기준 저장
    // { "language": "ko", "country": "KR", "category": "CASINO" }
    metadata Json @default("{}")

    // [Policies]
    slowModeSeconds Int @default(0) @map("slow_mode_seconds")
    minTierLevel    Int @default(0) @map("min_tier_level")

    // [Support Specific Fields] - SUPPORT 타입인 경우 사용
    supportStatus   SupportStatus?   @map("support_status")
    supportPriority SupportPriority? @map("support_priority")
    supportCategory SupportCategory? @map("support_category")
    supportSubject  String?          @map("support_subject")
    supportAdminId  BigInt?          @map("support_admin_id") // 담당 상담원

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    /// 마지막 메시지 시각 (목록 정렬 성능 최적화)
    lastMessageAt DateTime? @map("last_message_at")

    messages ChatMessage[]
    members  ChatRoomMember[]
    admin    User?            @relation("AdminAssignedRooms", fields: [supportAdminId], references: [id])

    @@index([type, isActive])
    @@map("chat_rooms")
}

model ChatRoomMember {
    id     BigInt @id @default(autoincrement())
    roomId BigInt @map("room_id")
    userId BigInt @map("user_id")

    role ChatMemberRole @default(MEMBER)

    // 마지막으로 읽은 메시지의 ID (안 읽은 메시지 계산용)
    lastReadMessageId BigInt? @map("last_read_message_id")

    room ChatRoom @relation(fields: [roomId], references: [id])
    user User     @relation(fields: [userId], references: [id])

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([roomId, userId])
    @@map("chat_room_members")
}

model ChatMessage {
    /// Snowflake ID (Application Generated)
    id       BigInt
    roomId   BigInt  @map("room_id")
    senderId BigInt? @map("sender_id") // null일 경우 시스템 메시지

    content String
    type    ChatMessageType

    // 이모지, 멘션, 이미지 URL 또는 커스텀 스타일
    metadata Json?

    isPinned  Boolean @default(false) @map("is_pinned")
    isDeleted Boolean @default(false) @map("is_deleted")

    createdAt DateTime @default(now()) @map("created_at")

    room   ChatRoom @relation(fields: [roomId], references: [id])
    sender User?    @relation("UserMessages", fields: [senderId], references: [id])

    /// 파티셔닝을 위해 PK에 created_at 포함
    @@id([id, createdAt])
    @@index([roomId, createdAt])
    @@index([createdAt])
    @@map("chat_messages")
}

enum ChatRoomType {
    PUBLIC // 누구나 참여 가능한 공개방 (Global)
    SUPPORT // 고객응대 1:1 (Admin <-> User)
}

enum SupportStatus {
    ENTERED // 상담방 생성 및 입장 직후 (유저의 첫 메시지 대기)
    OPEN // 유저 문의 발생 (관리자 답변 대기)
    IN_PROGRESS // 상담원이 답변 및 대화 중
    PENDING // 유저의 추가 답변이나 외부 처리를 기다리는 중 (펜딩 상태에서 유저가 메시지 보내면 알람 처리)
    CLOSED // 상담 종료
}

enum SupportPriority {
    LOW
    NORMAL
    HIGH
    URGENT
}

enum ChatMemberRole {
    MEMBER
    ADMIN
}

enum SupportCategory {
    ACCOUNT
    DEPOSIT
    WITHDRAWAL
    GAME
    PROMOTION
    ETC
}

enum ChatMessageType {
    TEXT
    IMAGE
    EMOJI
    SYSTEM // 유저 입장/퇴장 등
    ANNOUNCEMENT // 공지사항
}
