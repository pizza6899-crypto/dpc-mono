model PromotionConfig {
  id Int @id @default(1)

  defaultAmlDepositMultiplier Decimal @default(1.0) @map("default_aml_deposit_multiplier") @db.Decimal(8, 4)
  defaultBonusExpiryDays      Int     @default(30) @map("default_bonus_expiry_days")
  isPromotionEnabled          Boolean @default(true) @map("is_promotion_enabled")

  // --- Audit ---
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by")

  updatedByUser User? @relation("PromotionConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@map("promotion_configs")
}

model Promotion {
  id                  BigInt                  @id @default(autoincrement())
  isActive            Boolean                 @default(true) @map("is_active")
  startDate           DateTime?               @map("start_date")
  endDate             DateTime?               @map("end_date")
  deletedAt           DateTime?               @map("deleted_at")
  targetType          PromotionTargetType     @map("target_type")
  maxUsagePerUser     Int?                    @map("max_usage_per_user")
  periodicResetType   PromotionResetType      @default(NONE) @map("periodic_reset_type")
  applicableDays      Int[]                   @default([]) @map("applicable_days")
  applicableStartTime DateTime?               @map("applicable_start_time") // 적용 시작 시간 (날짜 무시, 시간/분만 사용)
  applicableEndTime   DateTime?               @map("applicable_end_time") // 적용 종료 시간 (날짜 무시, 시간/분만 사용)
  bonusExpiryMinutes  Int?                    @map("bonus_expiry_minutes")
  adminMemos          AdminMemo[]
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  createdBy           BigInt?                 @map("created_by")
  updatedBy           BigInt?                 @map("updated_by")
  createdByUser       User?                   @relation("PromotionCreatedBy", fields: [createdBy], references: [id])
  updatedByUser       User?                   @relation("PromotionUpdatedBy", fields: [updatedBy], references: [id])
  translations        PromotionTranslation[]
  currencyRules       PromotionCurrencyRule[]
  userPromotions      UserPromotion[]
  depositDetails      DepositDetail[]

  @@map("promotions")
}

model PromotionTranslation {
  id          BigInt    @id @default(autoincrement())
  promotionId BigInt    @map("promotion_id")
  language    Language
  title       String    @map("title") // 프로모션 제목 (사용자 노출용)
  description String?   @map("description") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, language])
  @@index([language])
  @@index([promotionId])
  @@map("promotion_translations")
}

model PromotionCurrencyRule {
  id                 BigInt               @id @default(autoincrement())
  promotionId        BigInt               @map("promotion_id")
  currency           ExchangeCurrencyCode
  minDepositAmount   Decimal              @default(0) @map("min_deposit_amount") @db.Decimal(32, 18)
  maxDepositAmount   Decimal?             @map("max_deposit_amount") @db.Decimal(32, 18) // 입금 인정 최대 금액
  maxBonusAmount     Decimal?             @map("max_bonus_amount") @db.Decimal(32, 18) // 최대 보너스 (또는 고정금액)
  maxWithdrawAmount  Decimal?             @map("max_withdraw_amount") @db.Decimal(32, 18) // 최대 출금 가능액 (Cash Conversion Cap)
  bonusRate          Decimal?             @map("bonus_rate") @db.Decimal(8, 4) // 해당 통화의 보너스 비율
  wageringMultiplier Decimal?             @map("wagering_multiplier") @db.Decimal(8, 4) // 해당 통화의 웨이저링(롤링) 배수
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  updatedBy          BigInt?              @map("updated_by")
  updatedByUser      User?                @relation("PromotionCurrencyRuleUpdatedBy", fields: [updatedBy], references: [id])
  promotion          Promotion            @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, currency])
  @@index([promotionId])
  @@index([currency])
  @@map("promotion_currency_rules")
}

model UserPromotion {
  id                    BigInt               @id @default(autoincrement())
  userId                BigInt               @map("user_id")
  promotionId           BigInt               @map("promotion_id")
  depositId             BigInt?              @map("deposit_id") // 트리거가 된 입금 ID
  wageringRequirementId BigInt?              @map("wagering_requirement_id") // 생성된 웨이저링 ID
  status                UserPromotionStatus  @default(ACTIVE)
  depositAmount         Decimal              @default(0) @map("deposit_amount") @db.Decimal(32, 18)
  bonusAmount           Decimal              @map("bonus_amount") @db.Decimal(32, 18)
  currency              ExchangeCurrencyCode

  /// 적용 당시의 정책 스냅샷
  policySnapshot      Json                 @map("policy_snapshot")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  completedAt         DateTime?            @map("completed_at")
  voidedAt            DateTime?            @map("voided_at")
  adminMemos          AdminMemo[]
  promotion           Promotion            @relation(fields: [promotionId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  deposit             DepositDetail?       @relation(fields: [depositId], references: [id])
  wageringRequirement WageringRequirement? @relation(fields: [wageringRequirementId], references: [id])

  @@index([userId, status])
  @@index([depositId])
  @@index([wageringRequirementId])
  @@map("user_promotions")
}

/**
 * 프로모션 타겟 타입
 * 프로모션이 적용되는 대상 사용자 유형
 */
enum PromotionTargetType {
  /// 생애 첫 입금
  FIRST_DEPOSIT
  /// 2차 입금
  SECOND_DEPOSIT
  /// 3차 입금
  THIRD_DEPOSIT
  /// 일반 재충전 (무한 또는 횟수제한)
  RELOAD_DEPOSIT
  /// 첫 출금 전까지 무제한
  BEFORE_FIRST_WITHDRAWAL
}

/**
 * 프로모션 참여 횟수 초기화 주기
 */
enum PromotionResetType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

/**
 * 사용자 프로모션 상태
 * 사용자가 참여한 프로모션의 현재 상태
 */
enum UserPromotionStatus {
  /// 진행 중 - 롤링 진행 중인 상태
  ACTIVE
  /// 롤링 달성 완료 - 롤링 완료하여 출금 가능한 상태
  COMPLETED
  /// 무효화 - 관리자 취소 또는 출금 등으로 인해 무효화된 상태
  VOIDED
  /// 기간 만료 - 프로모션 기간이 만료된 상태
  EXPIRED
}
