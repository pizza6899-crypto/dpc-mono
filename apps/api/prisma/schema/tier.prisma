model TierConfig {
  id BigInt @id @default(1) // 실제로는 id=1 인 row 하나만 사용

  // [Master Switch] 시스템 제어
  isUpgradeEnabled   Boolean @default(true) @map("is_upgrade_enabled") // 승급 심사 전체 ON/OFF
  isDowngradeEnabled Boolean @default(false) @map("is_downgrade_enabled") // 강등 심사 전체 ON/OFF
  isBonusEnabled     Boolean @default(true) @map("is_bonus_enabled") // 보너스 지급 전체 ON/OFF

  // [Default Policy] 기본 정책
  defaultDowngradeGracePeriodDays Int @default(7) @map("default_downgrade_grace_period_days") // 기본 강등 유예 기간 (Days)
  defaultRewardExpiryDays         Int @default(30) @map("default_reward_expiry_days") // 기본 보상 수령 만료 기간 (Days)

  // [Audit] 누가 언제 바꿨나
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by") // 변경한 관리자 ID

  // [XP Policy]
  // 1 XP를 획득하기 위해 필요한 롤링 금액 (USD)
  // 예: 10.00 이면 10달러 롤링당 1 XP 지급
  rollingUsdPerExp Decimal @default(1) @map("rolling_usd_per_exp") @db.Decimal(32, 18)

  updatedByUser User? @relation("TierConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@map("tier_config")
}

model Tier {
  id    BigInt @id @default(autoincrement())
  level Int    @unique // Higher value means higher tier level (e.g., 1=Bronze, 2=Silver)
  // code: 시스템 내부 식별자 (불변), 어드민/백오피스 및 코드 레벨 참조용 (e.g., "BRONZE", "VIP_GOLD")
  code  String @unique

  // evaluation_cycle: 등급 유지/강등 심사 주기
  // NONE: 강등 없음, ROLLING_30_DAYS: 30일 평가, ROLLING_90_DAYS: 90일 평가
  evaluationCycle TierEvaluationCycle @default(NONE) @map("evaluation_cycle")

  // [Gaming XP]
  // 다음 레벨 승급에 필요한 XP
  upgradeExpRequired BigInt @default(0) @map("upgrade_exp_required")

  // Benefits
  upgradeBonusUsd                Decimal @default(0) @map("upgrade_bonus_usd") @db.Decimal(32, 18)
  upgradeBonusWageringMultiplier Decimal @default(0) @map("upgrade_bonus_wagering_multiplier") @db.Decimal(8, 4) // 승급 보너스 베팅 요구 배수 (0=즉시 출금)
  isImmediateBonusEnabled        Boolean @default(false) @map("is_immediate_bonus_enabled") // 해당 티어 승급 시 보너스 즉시 지급 여부
  compRate                       Decimal @default(0) @map("comp_rate") @db.Decimal(8, 4) // 통합 컴프 요율
  weeklyLossbackRate             Decimal @default(0) @map("weekly_lossback_rate") @db.Decimal(8, 4) // 주간 루징백(캐시백) 요율
  monthlyLossbackRate            Decimal @default(0) @map("monthly_lossback_rate") @db.Decimal(8, 4) // 월간 루징백(캐시백) 요율

  dailyWithdrawalLimitUsd Decimal @default(0) @map("daily_withdrawal_limit_usd") @db.Decimal(32, 18)
  isWithdrawalUnlimited   Boolean @default(false) @map("is_withdrawal_unlimited") // True일 경우 한도 무시 (무제한)

  hasDedicatedManager Boolean @default(false) @map("has_dedicated_manager")
  rewardExpiryDays    Int?    @map("reward_expiry_days") // 해당 등급 승급 보너스 수령 만료 기간 (Days, Null 일 경우 전역 설정 따름)

  isActive     Boolean @default(true) @map("is_active") // 해당 등급 활성 여부 (비활성 시 승급 대상에서 제외)
  isHidden     Boolean @default(false) @map("is_hidden") // UI 노출 여부 (VIP 전용 등급 등)
  isManualOnly Boolean @default(false) @map("is_manual_only") // [추가] true일 경우 자동 배치 심사에서 제외, 오직 관리자 수동 승급만 가능

  // UI & Additional Info
  imageUrl String? @map("image_url") // 등급 아이콘/뱃지 이미지 URL

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by") // 변경한 관리자 ID

  updatedByUser User? @relation("TierUpdatedBy", fields: [updatedBy], references: [id])

  userTiers    UserTier[]
  translations TierTranslation[]
  historyFrom  TierHistory[]     @relation("HistoryFrom")
  historyTo    TierHistory[]     @relation("HistoryTo")

  stats TierStats[]

  downgradeTargetUserTiers UserTier[] @relation("DowngradeTarget")

  @@index([level])
  @@map("tier")
}

model TierTranslation {
  id BigInt @id @default(autoincrement())

  tierId      BigInt   @map("tier_id")
  language    Language
  name        String // Display name (e.g., "브론즈", "Bronze")
  description String?  @db.Text // 등급 혜택 상세 설명 (UI 노출용)

  tier Tier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, language])
  @@index([language])
  @@map("tier_translation")
}

model UserTier {
  id     BigInt @id @default(autoincrement())
  userId BigInt @unique @map("user_id")
  tierId BigInt @map("tier_id")

  // 상태 데이터
  lifetimeRollingUsd Decimal  @default(0) @map("lifetime_rolling_usd") @db.Decimal(32, 18)
  statusRollingUsd   Decimal  @default(0) @map("status_rolling_usd") @db.Decimal(32, 18) // (통계용) 현재 등급 누적 롤링액
  lifetimeDepositUsd Decimal  @default(0) @map("lifetime_deposit_usd") @db.Decimal(32, 18) // 평생 누적 입금액
  lastEvaluationAt   DateTime @default(now()) @map("last_evaluation_at")

  // 승급/강등 제어
  // [Policy: Soft Landing & Reset]
  // - 강등 확정 시: Level 산술 연산(-1)이 아닌, 현재 등급보다 낮은 Level 중에서 '가장 높은 등급'을 찾아 이동 (Next Lower Tier)
  // - 평가 주기 리셋: 강등과 동시에 lastEvaluationAt을 현재(Now)로 갱신하여 즉시 재강등 방지 및 활동 기회 부여
  currentLevel               Int            @default(0) @map("current_level") // 현재 등급 (정렬 및 인덱싱용)
  maxLevelAchieved           Int            @default(0) @map("max_level_achieved") // 보너스 중복 지급 방지용 (최고 달성 레벨)
  lastBonusReceivedAt        DateTime?      @map("last_bonus_received_at") // 마지막 승급 보너스 수령 시점
  status                     UserTierStatus @default(ACTIVE) @map("status") // ACTIVE, GRACE, LOCKED
  downgradeGracePeriodEndsAt DateTime?      @map("downgrade_grace_period_ends_at") // 강등 유예 종료 시점
  lastTierChangedAt          DateTime       @default(now()) @map("last_tier_changed_at")
  lastUpgradeAt              DateTime?      @map("last_upgrade_at") // 마지막 승급 시점 (마케팅 타겟팅용)
  lastDowngradeAt            DateTime?      @map("last_downgrade_at") // 마지막 강등 시점

  // [Advanced Retention] VIP 매니저 오버라이드 (기본 Tier 혜택보다 우선 적용)
  customCompRate            Decimal? @map("custom_comp_rate") @db.Decimal(8, 4)
  customWeeklyLossbackRate  Decimal? @map("custom_weekly_lossback_rate") @db.Decimal(8, 4)
  customMonthlyLossbackRate Decimal? @map("custom_monthly_lossback_rate") @db.Decimal(8, 4)

  customWithdrawalLimitUsd    Decimal? @map("custom_withdrawal_limit_usd") @db.Decimal(32, 18)
  isCustomWithdrawalUnlimited Boolean? @map("is_custom_withdrawal_unlimited")

  isCustomDedicatedManager Boolean? @map("is_custom_dedicated_manager")

  note String? @map("note") // 관리자 메모

  // [Risk Management] 승급은 시키되 현금성 보너스 지급은 차단 (기본값 true=지급)
  isBonusEligible Boolean @default(true) @map("is_bonus_eligible")

  // [Preference] 보너스 자동 지급 및 클레임 기본 통화 (없으면 즉시지급 X)
  preferredRewardCurrency ExchangeCurrencyCode? @map("preferred_reward_currency")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // [XP Status]
  statusExp   BigInt @default(0) @map("status_exp") // 승급 판정 시 사용되는 XP (승급 시 초기화 정책에 따름)
  lifetimeExp BigInt @default(0) @map("lifetime_exp") // 평생 누적 XP (UI 표시 및 랭킹용)

  nextEvaluationAt DateTime? @map("next_evaluation_at")

  // --- Downgrade Warning State ---
  downgradeWarningIssuedAt     DateTime? @map("downgrade_warning_issued_at")
  downgradeWarningTargetTierId BigInt?   @map("downgrade_warning_target_tier_id")

  user                       User  @relation(fields: [userId], references: [id])
  tier                       Tier  @relation(fields: [tierId], references: [id])
  downgradeWarningTargetTier Tier? @relation("DowngradeTarget", fields: [downgradeWarningTargetTierId], references: [id])

  @@index([userId])
  @@index([tierId])
  @@index([nextEvaluationAt, status])
  @@map("user_tier")
}

model TierHistory {
  id     BigInt
  userId BigInt @map("user_id")

  fromTierId BigInt?        @map("from_tier_id")
  toTierId   BigInt         @map("to_tier_id")
  changeType TierChangeType @map("change_type") // UPGRADE, DOWNGRADE, MANUAL, INITIAL
  reason     String?

  // Snapshot data (변경 시점의 데이터 기록)
  statusRollingUsdSnap    Decimal @default(0) @map("status_rolling_usd_snap") @db.Decimal(32, 18)
  compRateSnap            Decimal @default(0) @map("comp_rate_snap") @db.Decimal(8, 4)
  weeklyLossbackRateSnap  Decimal @default(0) @map("weekly_lossback_rate_snap") @db.Decimal(8, 4)
  monthlyLossbackRateSnap Decimal @default(0) @map("monthly_lossback_rate_snap") @db.Decimal(8, 4)

  lifetimeRollingUsdSnap Decimal @default(0) @map("lifetime_rolling_usd_snap") @db.Decimal(32, 18)
  lifetimeDepositUsdSnap Decimal @default(0) @map("lifetime_deposit_usd_snap") @db.Decimal(32, 18)

  // [Reward Audit] 보너스 지급 관련
  hasBonusGenerated  Boolean @default(false) @map("has_bonus_generated")
  bonusAmountUsdSnap Decimal @default(0) @map("bonus_amount_usd_snap") @db.Decimal(32, 18)
  skippedReason      String? @map("skipped_reason")

  // [XP Snapshot]
  statusExpSnap BigInt @default(0) @map("status_exp_snap")

  changedAt DateTime @default(now()) @map("changed_at")
  changeBy  String?  @map("change_by")

  // [Audit] 변경을 유발한 원천 데이터 참조
  referenceType TierHistoryReferenceType? @map("reference_type")
  referenceId   BigInt?                   @map("reference_id")

  user     User  @relation(fields: [userId], references: [id])
  fromTier Tier? @relation("HistoryFrom", fields: [fromTierId], references: [id])
  toTier   Tier  @relation("HistoryTo", fields: [toTierId], references: [id])

  @@id([id, changedAt]) // 파티셔닝 대응을 위한 복합 PK
  @@index([userId, changedAt(sort: Desc)])
  @@map("tier_history")
}

// 1. 등급별 시계열 통계 요약 (모니터링 및 대시보드용)
model TierStats {
  // timestamp: 해당 통계 구간의 시작 시각 (UTC)
  // 시계열 분석을 위해 분/초를 0으로 맞춘 정시(Hourly) 단위 또는 00:00:00(Daily) 단위의 값을 가집니다.
  timestamp DateTime @map("timestamp")
  tierId    BigInt   @map("tier_id")

  // [Snapshot] 해당 시점의 해당 등급 총 유저 수
  snapshotUserCount Int @default(0) @map("snapshot_user_count")

  // [Metrics] 해당 구간(예: 1시간) 동안 발생한 합계 데이터
  periodBonusPaidUsd Decimal @default(0) @map("period_bonus_paid_usd") @db.Decimal(32, 18)
  periodRollingUsd   Decimal @default(0) @map("period_rolling_usd") @db.Decimal(32, 18)
  periodDepositUsd   Decimal @default(0) @map("period_deposit_usd") @db.Decimal(32, 18) // 해당 구간 동안 발생한 합계 입금액

  // [Changes] 해당 구간 동안 발생한 티어 변동 및 심사 결과 인원 수
  upgradedCount   Int @default(0) @map("upgraded_count") // 승급 인원
  downgradedCount Int @default(0) @map("downgraded_count") // 강등 인원
  maintainedCount Int @default(0) @map("maintained_count") // 유지 인원
  graceCount      Int @default(0) @map("grace_count") // 유예 대상 인원

  updatedAt DateTime @updatedAt @map("updated_at")

  tier Tier @relation(fields: [tierId], references: [id])

  @@id([timestamp, tierId])
  @@map("tier_stats")
}

enum TierHistoryReferenceType {
  CASINO_ROUND // 카지노 게임 결과 (Round 테이블 ID)
  WALLET_TRANSACTION // 입금/출금 등 거래 (Transaction 테이블 ID)
  ADMIN_LOG // 관리자 수동 조작 (AdminActionLog 테이블 ID)
}

enum TierChangeType {
  INITIAL // 초기 등급
  UPGRADE // 승급
  DOWNGRADE // 강등
  MANUAL_UPDATE // 관리자 수동 변경
  CORRECTION // 오류 정정 (관리자 실수 등)
}

enum TierEvaluationCycle {
  NONE // 평가 없음 (강등 없음, 평생 유지)
  ROLLING_30_DAYS // 최근 30일 기준 순환 평가
  ROLLING_90_DAYS // 최근 90일 기준 순환 평가
}

enum UserTierStatus {
  ACTIVE // 정상 유지
  GRACE // 강등 유예 (Grace Period)
  LOCKED // 등급 고정 (Retention Lock / 관리자 수동 고정)
}

// --- XP Gamification Models ---

model UserExpLog {
  id     BigInt
  userId BigInt @map("user_id")

  amount        BigInt // 증감량 (+ 또는 -)
  statusExpSnap BigInt @map("status_exp_snap") // 지급 후 최종 잔액 스냅샷

  sourceType  ExpSourceType @map("source_type")
  referenceId BigInt?       @map("reference_id") // CasinoGameRound ID 등 원천 데이터 참조

  reason String? // 관리자 조정 시 사유 등

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@id([id, createdAt])
  @@unique([id])
  @@index([userId, createdAt])
  @@map("user_exp_log")
}

enum ExpSourceType {
  ROLLING_REWARD // 롤링에 따른 자동 지급
  ADMIN_ADJUSTMENT // 관리자 수동 조정
  EVENT_BONUS // 이벤트성 지급
  MISSION_COMPLETE // 미션 달성 보상
}
