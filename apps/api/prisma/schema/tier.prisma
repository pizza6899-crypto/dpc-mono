model TierConfig {
  id BigInt @id @default(autoincrement()) // 실제로는 id=1 인 row 하나만 사용

  // [Master Switch] 시스템 제어
  isPromotionEnabled Boolean @default(true) @map("is_promotion_enabled") // 승급 심사 전체 ON/OFF
  isDowngradeEnabled Boolean @default(false) @map("is_downgrade_enabled") // 강등 심사 전체 ON/OFF
  isBonusEnabled     Boolean @default(true) @map("is_bonus_enabled") // 보너스 지급 전체 ON/OFF

  // [Default Policy] 기본 정책
  defaultGracePeriodDays Int @default(7) @map("default_grace_period_days") // 기본 강등 유예 기간 (Days)

  // [Scheduler] 배치 심사 설정
  triggerIntervalMinutes Int @default(60) @map("trigger_interval_minutes") // 심사 트리거 주기 (분 단위)

  // [Audit] 누가 언제 바꿨나
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by") // 변경한 관리자 ID

  updatedByUser User? @relation("TierConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@map("tier_config")
}

model Tier {
  id   BigInt @id @default(autoincrement())
  rank Int    @unique // Higher value means higher tier (e.g., 1=Bronze, 2=Silver)
  // code: 시스템 내부 식별자 (불변), 어드민/백오피스 및 코드 레벨 참조용 (e.g., "BRONZE", "VIP_GOLD")
  code String @unique

  // requirement_usd: 승급에 필요한 누적 롤링액
  requirementUsd        Decimal @map("requirement_usd") @db.Decimal(32, 18)
  // requirement_deposit_usd: 승급에 필요한 누적 입금액
  requirementDepositUsd Decimal @default(0) @map("requirement_deposit_usd") @db.Decimal(32, 18)
  // maintenance_rolling_usd: 등급 유지를 위해 평가 주기(evaluation_cycle) 동안 달성해야 할 최소 롤링액
  // [Policy] 현재 정책상 강등(Demotion)은 없으므로 0으로 설정하여 비활성화합니다.
  maintenanceRollingUsd Decimal @default(0) @map("maintenance_rolling_usd") @db.Decimal(32, 18)

  // evaluation_cycle: 등급 유지/강등 심사 주기
  // NONE: 강등 없음, ROLLING_30_DAYS: 30일 평가, ROLLING_90_DAYS: 90일 평가
  evaluationCycle TierEvaluationCycle @default(NONE) @map("evaluation_cycle")

  // Benefits
  levelUpBonusUsd                Decimal @default(0) @map("level_up_bonus_usd") @db.Decimal(32, 18)
  levelUpBonusWageringMultiplier Decimal @default(0) @map("level_up_bonus_wagering_multiplier") @db.Decimal(8, 4) // 승급 보너스 베팅 요구 배수 (0=즉시 출금)
  isImmediateBonusEnabled        Boolean @default(false) @map("is_immediate_bonus_enabled") // 해당 티어 승급 시 보너스 즉시 지급 여부
  compRate                       Decimal @default(0) @map("comp_rate") @db.Decimal(8, 4) // 통합 컴프 요율
  lossbackRate                   Decimal @default(0) @map("lossback_rate") @db.Decimal(8, 4) // 손실 기반 캐시백 요율
  rakebackRate                   Decimal @default(0) @map("rakeback_rate") @db.Decimal(8, 4) // 롤링 기반 레이크백 요율

  dailyWithdrawalLimitUsd Decimal @default(0) @map("daily_withdrawal_limit_usd") @db.Decimal(32, 18)
  isWithdrawalUnlimited   Boolean @default(false) @map("is_withdrawal_unlimited") // True일 경우 한도 무시 (무제한)

  hasDedicatedManager Boolean @default(false) @map("has_dedicated_manager")
  isVIPEventEligible  Boolean @default(false) @map("is_vip_event_eligible")
  reloadBonusRate     Decimal @default(0) @map("reload_bonus_rate") @db.Decimal(8, 4)

  // UI & Additional Info
  imageUrl String? @map("image_url") // 등급 아이콘/뱃지 이미지 URL

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by") // 변경한 관리자 ID

  updatedByUser User? @relation("TierUpdatedBy", fields: [updatedBy], references: [id])

  userTiers    UserTier[]
  translations TierTranslation[]
  historyFrom  TierHistory[]     @relation("HistoryFrom")
  historyTo    TierHistory[]     @relation("HistoryTo")

  stats TierStats[]

  demotionTargetUserTiers UserTier[]          @relation("DemotionTarget")
  bonusLevelUpRewards     TierLevelUpReward[]

  @@index([rank])
  @@map("tier")
}

model TierTranslation {
  id BigInt @id @default(autoincrement())

  tierId      BigInt   @map("tier_id")
  language    Language
  name        String // Display name (e.g., "브론즈", "Bronze")
  description String?  @db.Text // 등급 혜택 상세 설명 (UI 노출용)

  tier Tier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, language])
  @@index([language])
  @@map("tier_translation")
}

model UserTier {
  id     BigInt @id @default(autoincrement())
  userId BigInt @unique @map("user_id")
  tierId BigInt @map("tier_id")

  // 상태 데이터
  totalEffectiveRollingUsd Decimal  @default(0) @map("total_effective_rolling_usd") @db.Decimal(32, 18)
  currentPeriodRollingUsd  Decimal  @default(0) @map("current_period_rolling_usd") @db.Decimal(32, 18)
  totalDepositUsd          Decimal  @default(0) @map("total_deposit_usd") @db.Decimal(32, 18) // [추가] 평생 누적 입금액
  currentPeriodDepositUsd  Decimal  @default(0) @map("current_period_deposit_usd") @db.Decimal(32, 18) // 이번 주기 누적 입금액
  lastEvaluationAt         DateTime @default(now()) @map("last_evaluation_at")

  // 승급/강등 제어
  // [Policy: Soft Landing & Reset]
  // - 강등 확정 시: Rank 산술 연산(-1)이 아닌, 현재 등급보다 낮은 Rank 중에서 '가장 높은 등급'을 찾아 이동 (Next Lower Tier)
  // - 평가 주기 리셋: 강등과 동시에 lastEvaluationAt을 현재(Now)로 갱신하여 즉시 재강등 방지 및 활동 기회 부여
  highestPromotedRank Int            @default(0) @map("highest_promoted_rank") // 보너스 중복 지급 방지용
  lastBonusReceivedAt DateTime?      @map("last_bonus_received_at") // [추가] 마지막 승급 보너스 수령 시점 (안전장치)
  status              UserTierStatus @default(ACTIVE) @map("status") // ACTIVE, GRACE, LOCKED
  graceEndsAt         DateTime?      @map("grace_ends_at") // 강등 유예 종료 시점
  lastTierChangedAt   DateTime       @default(now()) @map("last_tier_changed_at")

  // [Advanced Retention] VIP 매니저 오버라이드 (기본 Tier 혜택보다 우선 적용)
  customCompRate        Decimal? @map("custom_comp_rate") @db.Decimal(8, 4)
  customLossbackRate    Decimal? @map("custom_lossback_rate") @db.Decimal(8, 4)
  customRakebackRate    Decimal? @map("custom_rakeback_rate") @db.Decimal(8, 4) // 추가: 레이크백 오버라이드
  customReloadBonusRate Decimal? @map("custom_reload_bonus_rate") @db.Decimal(8, 4) // 추가: 리로드 보너스 오버라이드

  customWithdrawalLimitUsd    Decimal? @map("custom_withdrawal_limit_usd") @db.Decimal(32, 18)
  isCustomWithdrawalUnlimited Boolean? @map("is_custom_withdrawal_unlimited")

  isCustomDedicatedManager Boolean? @map("is_custom_dedicated_manager") // 추가: 전담 매니저 여부 (Null=Tier따름)
  isCustomVipEventEligible Boolean? @map("is_custom_vip_event_eligible") // 추가: VIP 이벤트 대상 여부 (Null=Tier따름)

  note String? @map("note") // 관리자 메모 (e.g. "타사 VIP 영입")

  // [Risk Management] 승급은 시키되 현금성 보너스 지급은 차단 (기본값 true=지급)
  isBonusEligible Boolean @default(true) @map("is_bonus_eligible")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  nextEvaluationAt DateTime? @map("next_evaluation_at") // 다음 심사 예정 시각 (배치 최적화용)

  // --- Demotion Warning State ---
  demotionWarningIssuedAt     DateTime? @map("demotion_warning_issued_at")
  demotionWarningTargetTierId BigInt?   @map("demotion_warning_target_tier_id")

  user                      User  @relation(fields: [userId], references: [id])
  tier                      Tier  @relation(fields: [tierId], references: [id])
  demotionWarningTargetTier Tier? @relation("DemotionTarget", fields: [demotionWarningTargetTierId], references: [id])

  @@index([userId])
  @@index([tierId])
  @@index([nextEvaluationAt, status])
  @@map("user_tier")
}

model TierHistory {
  id     BigInt // 스노우플레이크 처리 권장 (파티셔닝 대응)
  userId BigInt @map("user_id")

  fromTierId BigInt?        @map("from_tier_id")
  toTierId   BigInt         @map("to_tier_id")
  changeType TierChangeType @map("change_type") // UPGRADE, DOWNGRADE, MANUAL, INITIAL
  reason     String? // "Rolling requirement met", "Admin manual update"

  // Snapshot data (변경 시점의 데이터 기록)
  rollingAmountSnap Decimal @default(0) @map("rolling_amount_snap") @db.Decimal(32, 18)
  depositAmountSnap Decimal @default(0) @map("deposit_amount_snap") @db.Decimal(32, 18)
  compRateSnap      Decimal @default(0) @map("comp_rate_snap") @db.Decimal(8, 4)
  lossbackRateSnap  Decimal @default(0) @map("lossback_rate_snap") @db.Decimal(8, 4)
  rakebackRateSnap  Decimal @default(0) @map("rakeback_rate_snap") @db.Decimal(8, 4)

  // [Snapshot: Rules & Status] 당시 정책 기준 및 유저 누적 상태
  requirementUsdSnap        Decimal @default(0) @map("requirement_usd_snap") @db.Decimal(32, 18)
  requirementDepositUsdSnap Decimal @default(0) @map("requirement_deposit_usd_snap") @db.Decimal(32, 18)
  cumulativeDepositUsdSnap  Decimal @default(0) @map("cumulative_deposit_usd_snap") @db.Decimal(32, 18)

  // [Reward Audit] 보너스 지급 관련
  hasBonusGenerated Boolean @default(false) @map("has_bonus_generated") // 보너스 객체(TierLevelUpReward) 생성 여부
  bonusAmountSnap   Decimal @default(0) @map("bonus_amount_snap") @db.Decimal(32, 18) // 지급된 보너스 금액 스냅샷
  skippedReason     String? @map("skipped_reason") // 지급이 아예 제외(Skip)된 사유

  changedAt DateTime @default(now()) @map("changed_at")
  changeBy  String?  @map("change_by") // "SYSTEM", "admin_uid"

  // [Audit] 변경을 유발한 원천 데이터 참조
  referenceType TierHistoryReferenceType? @map("reference_type")
  referenceId   BigInt?                   @map("reference_id") // RoundID, TXID, AdminLogID 등 (원인 데이터)

  user     User  @relation(fields: [userId], references: [id])
  fromTier Tier? @relation("HistoryFrom", fields: [fromTierId], references: [id])
  toTier   Tier  @relation("HistoryTo", fields: [toTierId], references: [id])

  @@id([id, changedAt]) // 파티셔닝 대응을 위한 복합 PK
  @@index([userId, changedAt(sort: Desc)])
  @@map("tier_history")
}

// 1. 등급별 시계열 통계 요약 (모니터링 및 대시보드용)
model TierStats {
  // timestamp: 해당 통계 구간의 시작 시각 (UTC)
  // 시계열 분석을 위해 분/초를 0으로 맞춘 정시(Hourly) 단위 또는 00:00:00(Daily) 단위의 값을 가집니다.
  timestamp DateTime @map("timestamp")
  tierId    BigInt   @map("tier_id")

  // [Snapshot] 해당 시점의 해당 등급 총 유저 수
  snapshotUserCount Int @default(0) @map("snapshot_user_count")

  // [Metrics] 해당 구간(예: 1시간) 동안 발생한 합계 데이터
  totalBonusPaidUsd Decimal @default(0) @map("total_bonus_paid_usd") @db.Decimal(32, 18)
  totalRollingUsd   Decimal @default(0) @map("total_rolling_usd") @db.Decimal(32, 18)
  totalDepositUsd   Decimal @default(0) @map("total_deposit_usd") @db.Decimal(32, 18) // [추가] 해당 구간 동안 발생한 합계 입금액

  // [Changes] 해당 구간 동안 발생한 티어 변동 및 심사 결과 인원 수
  promotedCount   Int @default(0) @map("promoted_count") // 승급 인원
  demotedCount    Int @default(0) @map("demoted_count") // 강등 인원
  maintainedCount Int @default(0) @map("maintained_count") // 유지 인원
  graceCount      Int @default(0) @map("grace_count") // 유예 대상 인원

  updatedAt DateTime @updatedAt @map("updated_at")

  tier Tier @relation(fields: [tierId], references: [id])

  @@id([timestamp, tierId])
  @@map("tier_stats")
}

enum TierHistoryReferenceType {
  CASINO_ROUND // 카지노 게임 결과 (Round 테이블 ID)
  WALLET_TRANSACTION // 입금/출금 등 거래 (Transaction 테이블 ID)
  ADMIN_LOG // 관리자 수동 조작 (AdminActionLog 테이블 ID)
}

enum TierChangeType {
  INITIAL // 초기 등급
  UPGRADE // 승급
  DOWNGRADE // 강등
  MANUAL_UPDATE // 관리자 수동 변경
}

enum TierEvaluationCycle {
  NONE // 평가 없음 (강등 없음, 평생 유지)
  ROLLING_30_DAYS // 최근 30일 기준 순환 평가
  ROLLING_90_DAYS // 최근 90일 기준 순환 평가
}

enum UserTierStatus {
  ACTIVE // 정상 유지
  GRACE // 강등 유예 (Grace Period)
  LOCKED // 등급 고정 (Retention Lock / 관리자 수동 고정)
}

model TierLevelUpReward {
  id     BigInt @id @default(autoincrement())
  userId BigInt @map("user_id")
  tierId BigInt @map("tier_id") // 승급된 목표 티어 ID

  // 승급 시점의 보너스 설정 스냅샷
  bonusAmount        Decimal @map("bonus_amount") @db.Decimal(32, 18)
  wageringMultiplier Decimal @map("wagering_multiplier") @db.Decimal(8, 4)

  status TierLevelUpRewardStatus @default(PENDING) @map("status")

  createdAt DateTime  @default(now()) @map("created_at")
  claimedAt DateTime? @map("claimed_at") // 실제 수령 시각

  // 사후 추적을 위한 참조 ID
  walletTxId      BigInt? @map("wallet_tx_id") // 지갑 트랜잭션 ID
  userPromotionId BigInt? @map("user_promotion_id") // 생성된 프로모션(롤링) ID
  tierHistoryId   BigInt? @map("tier_history_id") // 생성 원인이 된 승급 히스토리 ID (Snowflake)

  user User @relation(fields: [userId], references: [id])
  tier Tier @relation(fields: [tierId], references: [id])

  @@index([userId, status])
  @@index([tierId])
  @@map("tier_level_up_reward")
}

enum TierLevelUpRewardStatus {
  PENDING // 수령 대기
  CLAIMED // 수령 완료
  CANCELLED // 관리자 취소
}
