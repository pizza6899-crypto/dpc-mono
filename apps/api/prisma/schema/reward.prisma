model UserReward {
    id     BigInt // Snowflake ID (파티셔닝 복합키용으로 하단 선언)
    userId BigInt @map("user_id") // 수령 대상 유저
    user   User   @relation(fields: [userId], references: [id])

    // ✅ 1. 생성 출처 (누가/어떤 모듈이 이 보상(쿠폰)을 발행했는가?)
    sourceType RewardSourceType @map("source_type")
    sourceId   BigInt?          @map("source_id") // 외부 모듈 식별자 (TierUpgrade ID, Promotion ID 등)

    // ✅ 2. 지급될 내용물 (무엇을/얼마나 지급할 것인가?)
    rewardType RewardItemType       @map("reward_type") // 예: BONUS_MONEY (현금/보너스머니), FREE_SPIN (프리스핀)
    currency   ExchangeCurrencyCode @map("currency")
    amount     Decimal              @map("amount") @db.Decimal(32, 18)

    // ✅ 3. 부가 조건 (보상 수령 시 부여할 롤링 및 제약조건)
    wageringTargetType WageringTargetType @default(AMOUNT) @map("wagering_target_type") // 금액 기준 vs 횟수 기준 롤링
    wageringMultiplier Decimal?           @map("wagering_multiplier") // 0이면 캐시, N이면 해당하는 배수만큼 롤링 적용
    wageringExpiryDays Int?               @map("wagering_expiry_days") // 보상 수령(Claim) 후 며칠 내에 조건을 달성해야 하는가
    maxCashConversion  Decimal?           @map("max_cash_conversion") // 롤링 완료 시 최대 출금(전환) 한도 (NULL = 무제한)
    isForfeitable      Boolean            @default(true) @map("is_forfeitable") // 유저가 향후 이 보상을 자의로 포기 가능한지

    // ✅ 4. 생애 주기 (지급 대기부터, 완료 및 만료까지)
    status    RewardStatus @default(PENDING) @map("status")
    expiresAt DateTime?    @map("expires_at")
    claimedAt DateTime?    @map("claimed_at")

    // ✅ 5. 운영 및 다국어 메타데이터 (확장 필드)
    reason   String? // 지급 사유 또는 취소 사유 (어드민용)
    metadata Json? // 프론트 다국어 노출용 번역키(translationKey) 또는 프리스핀 게임 정보 등 유연한 저장소

    createdAt DateTime @map("created_at") // Snowflake ID에서 추출된 시간을 애플리케이션 계층에서 주입
    updatedAt DateTime @updatedAt @map("updated_at")

    @@id([id, createdAt])
    @@unique([id])
    @@index([userId, status, createdAt]) // 유저의 미수령 보상(PENDING) 조회용 
    @@index([sourceType, sourceId, createdAt]) // 연관된 이벤트 추적
    @@map("user_rewards")
}

// 보상의 지급 출처(도메인)
enum RewardSourceType {
    ADMIN_GRANT // 관리자가 수동으로 부여한 보상 (CS 보장, 이벤트 누락 대응 등)
    COMP_REWARD // 콤프/리베이트 스케줄러로 인한 지급
    TIER_REWARD // 승급/유지 등의 티어 혜택
    // PROMOTION_CODE // (향후 추가) 유저가 코드를 입력해 수령하는 프로모션 쿠폰
    // TOURNAMENT_PRIZE // (향후 추가) 토너먼트/에어드랍 입상 보상 등 확장용
    // SYSTEM_REBATE // (향후 추가) 기타 시스템 기반 리베이트 보상
}

// 보상의 종류 (단순 머니 지급 외에 프리스핀 티켓 등 확장 대비)
enum RewardItemType {
    BONUS_MONEY // 지갑 잔액으로 바로 전환
    // FREE_SPIN // 게임 플레이용 프리 스핀 (향후 지원 예정)
}

// 보상의 상태 변화
enum RewardStatus {
    PENDING // 미수령 (유저의 보상함에 노출됨)
    CLAIMED // 수령 완료 (Wallet / Wagering 처리됨)
    EXPIRED // 기간 만료로 인한 수령 불가
    VOIDED // 관리자 또는 시스템에 의한 지급 무효화
}
