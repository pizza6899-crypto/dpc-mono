/// [Artifact] 유물 등급 정의
enum ArtifactGrade {
  COMMON // 일반
  UNCOMMON // 고급
  RARE // 희귀
  EPIC // 영웅
  LEGENDARY // 전설
  MYTHIC // 신화
  UNIQUE // 유일
}

/// [Artifact] 유물 마스터 데이터 상태
enum ArtifactCatalogStatus {
  ACTIVE // 활성 (뽑기 노출 및 획득 가능)
  INACTIVE // 비활성 (데이터 유지, 신규 획득 불가)
  HIDDEN // 숨김 (시스템 점검 또는 예정 데이터)
}

/// [Artifact] 유물 뽑기(Gacha) 확률 설정
model ArtifactDrawConfig {
  grade       ArtifactGrade @id
  probability Decimal       @map("probability") @db.Decimal(10, 8)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("artifact_draw_configs")
}

/// [Artifact] 유물 정책
model ArtifactPolicy {
  id BigInt @id @default(1)

  /// [Artifact] 유물 뽑기 비용 설정 (JSON)
  /// - 지원 범위: 1회 뽑기(SINGLE), 10회 뽑기(TEN) 구분
  /// - 보너스 정책: 10회 뽑기 진행 시 1회 추가 지급 (총 11회 뽑기)
  /// - 멀티 커런시 대응: 통화별 가격 설정 가능
  /// - 예시 데이터 구조: { "SINGLE": { "USD": 10, "KRW": 10000 }, "TEN": { "USD": 100, "KRW": 100000 } }
  drawPrices Json @map("draw_prices")

  /// [Artifact] 유물 등급별 상세 합성 정책 설정 (JSON)
  /// - 지원 범위: 등급별 필요 개수, 합성 성공 확률 등
  /// - 예시 데이터 구조: { "COMMON": { "requiredCount": 3, "successRate": 1.0 }, "RARE": { "requiredCount": 3, "successRate": 0.7, "guaranteedCount": 5 } }
  synthesisConfigs Json @default("{}") @map("synthesis_configs")

  /// [Artifact] 레벨별 유물 슬롯 해금 설정 (JSON)
  /// - 기본 2칸 제공, 특정 레벨 도달 시 추가 해금
  /// - 예시 데이터 구조: { "unlockLevels": [1, 1] } (1번 1레벨, 2번 1레벨 해금)
  slotUnlockConfigs Json @default("{}") @map("slot_unlock_configs")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("artifact_policies")
}

/// [Artifact] 유물 마스터 데이터 (독립 시스템)
model ArtifactCatalog {
  id              BigInt                @id @default(autoincrement())
  code            String                @unique // 유물 고유 코드
  grade           ArtifactGrade
  drawWeight      Int                   @default(1000) @map("draw_weight") // 동일 등급 내 당첨 가중치
  // [Stats Bonus] 장착 시 합산되는 캐릭터 능력치 (Fixed Value)
  casinoBenefit   Int                   @default(0) @map("casino_benefit")
  slotBenefit     Int                   @default(0) @map("slot_benefit")
  sportsBenefit   Int                   @default(0) @map("sports_benefit")
  minigameBenefit Int                   @default(0) @map("minigame_benefit")
  badBeatBenefit  Int                   @default(0) @map("bad_beat_benefit")
  criticalBenefit Int                   @default(0) @map("critical_benefit")
  status          ArtifactCatalogStatus @default(ACTIVE) @map("status")
  imageUrl        String?               @map("image_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userArtifacts UserArtifact[]

  @@map("artifact_catalogs")
}

/// [Artifact] 유저별 유물 관련 상태 정보 (Pity/스택 등)
model UserArtifactStatus {
  userId BigInt @id @map("user_id")

  /// 현재 활성화된(해금된) 유물 슬롯 개수 (기본 2개 제공)
  activeSlotCount Int @default(0) @map("active_slot_count")

  /// 전체 누적 뽑기 횟수 (합산)
  totalDrawCount Int @default(0) @map("total_draw_count")

  /// 티켓을 사용한 누적 뽑기 횟수 (전체 합산)
  totalTicketDrawCount Int @default(0) @map("total_ticket_draw_count")

  /// [Stats] 등급별 티켓 사용 누적 횟수
  drawCountTicketAll       Int @default(0) @map("draw_count_ticket_all")
  drawCountTicketCommon    Int @default(0) @map("draw_count_ticket_common")
  drawCountTicketUncommon  Int @default(0) @map("draw_count_ticket_uncommon")
  drawCountTicketRare      Int @default(0) @map("draw_count_ticket_rare")
  drawCountTicketEpic      Int @default(0) @map("draw_count_ticket_epic")
  drawCountTicketLegendary Int @default(0) @map("draw_count_ticket_legendary")
  drawCountTicketMythic    Int @default(0) @map("draw_count_ticket_mythic")
  drawCountTicketUnique    Int @default(0) @map("draw_count_ticket_unique")

  /// 재화를 사용한 누적 뽑기 횟수
  totalCurrencyDrawCount Int @default(0) @map("total_currency_draw_count")

  /// 전체 누적 합성 시도 횟수
  totalSynthesisCount Int @default(0) @map("total_synthesis_count")

  /// [Stats] 등급별 합성 통계 (성공, 실패, 연속 실패 스택)
  /// COMMON
  synthesisCommonSuccessCount Int @default(0) @map("synthesis_common_success_count")
  synthesisCommonFailCount    Int @default(0) @map("synthesis_common_fail_count")

  /// UNCOMMON
  synthesisUncommonSuccessCount Int @default(0) @map("synthesis_uncommon_success_count")
  synthesisUncommonFailCount    Int @default(0) @map("synthesis_uncommon_fail_count")

  /// RARE
  synthesisRareSuccessCount Int @default(0) @map("synthesis_rare_success_count")
  synthesisRareFailCount    Int @default(0) @map("synthesis_rare_fail_count")

  /// EPIC
  synthesisEpicSuccessCount Int @default(0) @map("synthesis_epic_success_count")
  synthesisEpicFailCount    Int @default(0) @map("synthesis_epic_fail_count")

  /// LEGENDARY
  synthesisLegendarySuccessCount Int @default(0) @map("synthesis_legendary_success_count")
  synthesisLegendaryFailCount    Int @default(0) @map("synthesis_legendary_fail_count")

  /// MYTHIC
  synthesisMythicSuccessCount Int @default(0) @map("synthesis_mythic_success_count")
  synthesisMythicFailCount    Int @default(0) @map("synthesis_mythic_fail_count")

  /// UNIQUE
  synthesisUniqueSuccessCount Int @default(0) @map("synthesis_unique_success_count")
  synthesisUniqueFailCount    Int @default(0) @map("synthesis_unique_fail_count")

  /// [Artifact] 보유 중인 일반 뽑기권 수량 (등급 제한 없음)
  ticketAllCount Int @default(0) @map("ticket_all_count")

  /// [Artifact] 등급 확정권 수량 (등급별 각 1개 컬럼)
  ticketCommonCount    Int @default(0) @map("ticket_common_count")
  ticketUncommonCount  Int @default(0) @map("ticket_uncommon_count")
  ticketRareCount      Int @default(0) @map("ticket_rare_count")
  ticketEpicCount      Int @default(0) @map("ticket_epic_count")
  ticketLegendaryCount Int @default(0) @map("ticket_legendary_count")
  ticketMythicCount    Int @default(0) @map("ticket_mythic_count")
  ticketUniqueCount    Int @default(0) @map("ticket_unique_count")

  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("user_artifact_statuses")
}

/// [Artifact] 유물 소유 내역
model UserArtifact {
  id         BigInt @id @default(autoincrement())
  userId     BigInt @map("user_id")
  artifactId BigInt @map("artifact_id")

  // 장착 슬롯 번호 (null = 미장착, 1~n = 장착 슬롯 번호)
  slotNo     Int?    @map("slot_no")
  isEquipped Boolean @default(false) @map("is_equipped")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id])
  artifact ArtifactCatalog @relation(fields: [artifactId], references: [id])

  @@unique([userId, slotNo]) // 동일한 슬롯에 중복 장착 방지 (null 제외)
  @@index([userId])
  @@index([artifactId])
  @@map("user_artifacts")
}

/// [Artifact] 유물 뽑기 진행 상태
enum ArtifactDrawStatus {
  PENDING // 블록 생성 대기
  SETTLED // 서버가 결과 산출 및 아이템 지급 완료 (유저 확인 전)
  CLAIMED // 유저가 결과를 최종 확인(연출 시청) 완료
}

/// [Artifact] 유물 뽑기 타입
enum ArtifactDrawType {
  SINGLE // 1회 (1)
  TEN // 10회 (10+1 = 11)
}

/// [Artifact] 유물 뽑기 결제 수단
enum ArtifactDrawPaymentType {
  TICKET // 티켓 소모
  CURRENCY // 재화 소모
}

/// [Artifact] 유물 뽑기 요청 내역 (미래 블록 기반 Commit-Reveal 관리용)
model ArtifactDrawRequest {
  id           BigInt                  @id @default(autoincrement())
  userId       BigInt                  @map("user_id")
  targetSlot   BigInt                  @map("target_slot") // 향후 슬롯 번호 증가에 대비하여 BigInt 사용
  drawType     ArtifactDrawType        @map("draw_type")
  paymentType  ArtifactDrawPaymentType @map("payment_type")
  ticketType   String?                 @map("ticket_type") // ALL, ArtifactGrade 유연성 유지
  currencyCode ExchangeCurrencyCode?   @map("currency_code") // 사용된 재화 코드 (USD, KRW 등)
  status       ArtifactDrawStatus      @default(PENDING) @map("status")
  result       Json?                   @map("result") // 당첨 결과 [{ id: bigint, artifactId: string, grade: ArtifactGrade }, ...]

  settledAt DateTime? @map("settled_at") // 서버 확정 시점
  claimedAt DateTime? @map("claimed_at") // 유저 확인 시점
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([targetSlot, status])
  @@map("artifact_draw_requests")
}
