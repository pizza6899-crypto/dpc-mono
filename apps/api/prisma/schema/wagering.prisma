model WageringConfig {
  id BigInt @id @default(autoincrement()) // id=1 하나만 사용

  // [Default Policy]
  defaultBonusExpiryDays   Int     @default(30) @map("default_bonus_expiry_days") // 기본 보너스 유효기간 (일)
  defaultDepositMultiplier Decimal @default(1.0) @map("default_deposit_multiplier") @db.Decimal(8, 4) // 자금세탁 방지용 기본 입금 롤링 배수

  // [Currency Specific Policy]
  // 화폐별 오링 기준(threshold) 및 최소 베팅 보정치 등을 JSON으로 관리
  // 예: { "KRW": { "cancellationThreshold": 500 }, "USD": { "cancellationThreshold": 0.5 }, "BTC": { "cancellationThreshold": 0.00001 } }
  currencySettings Json @default("{}") @map("currency_settings")

  // [System Control]
  isWageringCheckEnabled    Boolean @default(true) @map("is_wagering_check_enabled") // 출금 시 롤링 체크 활성 여부
  isAutoCancellationEnabled Boolean @default(true) @map("is_auto_cancellation_enabled") // 오링 시 자동 취소 배치 활성 여부

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy BigInt?  @map("updated_by") // 변경한 관리자 ID

  @@map("wagering_config")
}

model WageringRequirement {
  id         BigInt               @id // Snowflake ID (Application Generated)
  userId     BigInt               @map("user_id")
  currency   ExchangeCurrencyCode
  sourceType WageringSourceType   @default(DEPOSIT) @map("source_type")

  // [목표 타입 설정]
  targetType WageringTargetType @default(AMOUNT) @map("target_type") // 롤링을 평가할 기준 (금액 vs 횟수)

  // 1. 금액 기반 (targetType = AMOUNT 일 때 사용)
  requiredAmount Decimal @map("required_amount") @db.Decimal(32, 18) // 목표 롤링 금액
  wageredAmount  Decimal @default(0) @map("wagered_amount") @db.Decimal(32, 18) // 현재까지 달성한 롤링 누적 금액 (기여도 반영)

  // 2. 횟수 기반 (targetType = ROUND_COUNT 일 때 사용)
  requiredCount Int @default(0) @map("required_count") // 목표 라운드 판수 (예: 10판)
  wageredCount  Int @default(0) @map("wagered_count") // 현재까지 플레이한 라운드 판수

  isAutoCancelable Boolean @default(true) @map("is_auto_cancelable") // 자동 취소(오링 처리) 허용 여부

  // [메타 데이터] - 원본 추적 및 운영 편의성
  principalAmount   Decimal @default(0) @map("principal_amount") @db.Decimal(32, 18) // 롤링 배수(multiplier)의 기준이 되는 총 금액 (Cash + Bonus 등)
  multiplier        Decimal @default(1) @map("multiplier") @db.Decimal(8, 4) // 적용된 롤링 배수 (예: 3.0)
  bonusAmount       Decimal @default(0) @map("bonus_amount") @db.Decimal(32, 18) // 지급된 보너스 금액
  initialFundAmount Decimal @default(0) @map("initial_fund_amount") @db.Decimal(32, 18) // 초기 지급 총액 (principalAmount + bonusAmount 등)

  // 생성 당시 적용된 Config/Rule의 사본 (정책 변경 추적용 스냅샷)
  // 예: { "minBet": 0.1, "excludedGames": ["A", "B"] }
  appliedConfig Json? @default("{}") @map("applied_config")

  // [펀드(자금) 흐름 추적]
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(32, 18) // 이 웨이저링(보너스/입금)에서 기원된 현재 가용 잔액 (베팅-당첨에 따라 실시간 변동)
  totalBetAmount Decimal @default(0) @map("total_bet_amount") @db.Decimal(32, 18) // 이 웨이저링 펀드로 베팅한 총액
  totalWinAmount Decimal @default(0) @map("total_win_amount") @db.Decimal(32, 18) // 이 웨이저링 펀드에서 발생한 총 당첨(수익) 금액

  // [혼합비율 및 출금전략 (Real Money + Bonus)]
  realMoneyRatio Decimal @default(0) @map("real_money_ratio") @db.Decimal(8, 4) // 총 초기 펀드 중에서, 실제 캐시(Real Money)가 차지하는 비율 (손실 통계 및 환불 시 기준)
  isForfeitable  Boolean @default(false) @map("is_forfeitable") // 보너스 중도 포기(Forfeit) 시 현금 환불 가능 여부

  // [정산 규칙 및 결과]
  maxCashConversion Decimal? @map("max_cash_conversion") @db.Decimal(32, 18) // 롤링 완료 시 Cash 전환 상한액 (NULL=무제한)
  convertedAmount   Decimal? @map("converted_amount") @db.Decimal(32, 18) // 롤링 완료 후 실제 Cash로 전환된 금액

  // 상태
  isPaused Boolean        @default(false) @map("is_paused") // 관리자 조사 등으로 인한 진행 일시 정지
  status   WageringStatus @default(ACTIVE)

  // 링크 (Polymorphic Association)
  // sourceType(DEPOSIT, PROMOTION)과 조합하여 원천 데이터를 식별합니다.
  sourceId BigInt @map("source_id")

  // 타임스탬프
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  expiresAt         DateTime? @map("expires_at")
  lastContributedAt DateTime? @map("last_contributed_at") // 마지막 기여 발생 시간

  // [완료/취소 이력]
  completedAt            DateTime?                   @map("completed_at")
  cancelledAt            DateTime?                   @map("cancelled_at")
  cancellationNote       String?                     @map("cancellation_note") // 취소/무효화 사유 (자유 텍스트)
  cancellationReasonType WageringCancellationReason? @map("cancellation_reason_type") // 시스템/관리자 취소 사유 코드
  cancelledBy            String?                     @map("cancelled_by") // 취소 실행자 ('SYSTEM' or 'ADMIN:123')
  balanceAtCancellation  Decimal?                    @map("balance_at_cancellation") @db.Decimal(32, 18) // 취소 시점의 유저 유효 잔액 (증빙용)
  forfeitedAmount        Decimal?                    @map("forfeited_amount") @db.Decimal(32, 18) // 취소로 인해 실제 회수(차감)된 금액 (Delta)

  // 우선순위 (높을수록 먼저 차감, 예: 기간제 보너스 우선)
  priority Int @default(0)

  // Relations
  user             User                      @relation(fields: [userId], references: [id])
  contributionLogs WageringContributionLog[]

  // [Wagering History] 롤링 전환/파생 이력
  parentWageringId BigInt?               @map("parent_wagering_id")
  parentWagering   WageringRequirement?  @relation("WageringHistory", fields: [parentWageringId], references: [id])
  childWagerings   WageringRequirement[] @relation("WageringHistory")

  @@index([userId, status, currency, priority])
  @@index([userId, status])
  @@index([sourceId, sourceType]) // 원천 데이터로 역조회 시 사용
  @@index([status])
  @@map("wagering_requirements")
}

model WageringContributionLog {
  id                    BigInt // Snowflake ID (Application Generated)
  wageringRequirementId BigInt @map("wagering_requirement_id")
  gameRoundId           BigInt @map("game_round_id")

  requestAmount    Decimal @map("request_amount") @db.Decimal(32, 18) // 원래 베팅액
  contributionRate Decimal @map("contribution_rate") @db.Decimal(8, 4) // 당시 기여도
  wageredAmount    Decimal @map("wagered_amount") @db.Decimal(32, 18) // 실제 차감(기여)된 롤링 금액

  createdAt DateTime @default(now()) @map("created_at")

  wageringRequirement WageringRequirement @relation(fields: [wageringRequirementId], references: [id])

  // [Partitioning] 시간 기반 파티셔닝을 위해 PK에 시간 포함
  @@id([id, createdAt])
  @@index([wageringRequirementId, createdAt]) // 특정 웨이저링 조건의 기여 내역 타임라인 조회
  @@index([gameRoundId]) // 특정 게임 한 판이 기여한 로그 역추적
  @@index([createdAt]) // 기간별 통계 조회용
  @@map("wagering_contribution_logs")
}

enum WageringSourceType {
  DEPOSIT
  PROMOTION_BONUS
  TIER_BONUS
}

enum WageringTargetType {
  AMOUNT // 베팅 금액(wageredAmount) 누적 기준
  ROUND_COUNT // 플레이 횟수(wageredCount) 누적 기준
}

enum WageringStatus {
  /// 활성 - 롤링 조건을 채워야 함
  ACTIVE
  /// 완료 - 롤링 조건 충족 완료
  COMPLETED
  /// 취소됨 - 잔액 부족(오링)으로 자연 소멸
  CANCELLED
  /// 만료됨 - 기간 만료로 인한 종료 (보너스 회수 대상)
  EXPIRED
  /// 무효화됨 - 관리자 또는 시스템에 의한 강제 취소
  VOIDED
}

enum WageringCancellationReason {
  /// 잔액 부족으로 인한 자동 취소 (오링)
  BANKRUPTCY
  /// 유효기간 만료
  EXPIRED
  /// 관리자에 의한 수동 취소
  MANUAL_ADMIN
  /// 유저 요청에 의한 포기
  USER_FORFEIT
  /// 시스템 오류 또는 롤백
  SYSTEM_ERROR
  /// 어뷰징 등 규정 위반으로 인한 몰수
  VIOLATION
}
