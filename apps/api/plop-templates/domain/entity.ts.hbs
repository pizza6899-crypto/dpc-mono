// src/modules/{{modulePath}}/domain/model/{{kebabCase entityName}}.entity.ts

export class {{pascalCase entityName}} {
  private constructor(
    public readonly id: string,
    public readonly createdAt: Date,
    public readonly updatedAt: Date,
  ) {}

  /**
   * DB에서 조회한 데이터로부터 엔티티 생성
   * Repository에서 Prisma를 통해 생성/조회된 데이터를 Domain Entity로 변환할 때 사용
   * @param data - DB에서 조회한 데이터
   * @returns {{pascalCase entityName}} 엔티티 인스턴스
   */
  static fromPersistence(data: {
    id: string;
    createdAt: Date;
    updatedAt: Date;
  }): {{pascalCase entityName}} {
    return new {{pascalCase entityName}}(
      data.id,
      data.createdAt,
      data.updatedAt,
    );
  }

  /**
   * Domain 엔티티를 Persistence 레이어로 변환
   * @returns Persistence 레이어에 저장할 데이터
   */
  toPersistence(): {
    id: string;
    createdAt: Date;
    updatedAt: Date;
  } {
    return {
      id: this.id,
      createdAt: this.createdAt,
      updatedAt: this.updatedAt,
    };
  }
}

