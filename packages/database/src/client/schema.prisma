  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastUsedAt   DateTime?
  user         User       @relation("AffiliateCodes", fields: [userId], references: [id], onDelete: Cascade)
  referrals    Referral[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([code])
