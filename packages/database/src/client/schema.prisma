}

model UserPromotion {
  id                   BigInt               @id @default(autoincrement())
  userId               BigInt               @map("user_id")
  promotionId          BigInt               @map("promotion_id")
  status               UserPromotionStatus  @default(ACTIVE)
  depositAmount        Decimal              @map("deposit_amount") @db.Decimal(32, 18)
  bonusAmount          Decimal              @map("bonus_amount") @db.Decimal(32, 18)
  targetRollingAmount  Decimal              @map("target_rolling_amount") @db.Decimal(32, 18)
  currentRollingAmount Decimal              @default(0) @map("current_rolling_amount") @db.Decimal(32, 18)
  currency             ExchangeCurrencyCode
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  Rolling              Rolling[]
  promotion            Promotion            @relation(fields: [promotionId], references: [id])
  user                 User                 @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("user_promotions")
}

/**
 * 프로모션 타겟 타입
 * 프로모션이 적용되는 대상 사용자 유형
 */
enum PromotionTargetType {
  /// 신규 유저 첫 입금 - 신규 가입 후 첫 입금 시 적용
  NEW_USER_FIRST_DEPOSIT
  // 추천 추가 값들:
  // EXISTING_USER_DEPOSIT      // 기존 유저 입금
  // WEEKLY_DEPOSIT              // 주간 입금 프로모션
  // MONTHLY_DEPOSIT             // 월간 입금 프로모션
  // BIRTHDAY                    // 생일 프로모션
  // VIP_LEVEL_UP                // VIP 레벨업 프로모션
  // REFERRAL_BONUS              // 추천인 보너스
  // LOYALTY_REWARD              // 로열티 보상
}

/**
 * 프로모션 보너스 타입
 * 보너스 지급 방식
 */
enum PromotionBonusType {
  /// 퍼센트 기반 보너스 - 입금 금액의 일정 비율로 지급
  PERCENTAGE
  // 추천 추가 값들:
  // FIXED_AMOUNT                // 고정 금액 보너스
  // FREE_SPINS                  // 무료 스핀
  // CASHBACK                    // 캐시백
  // MATCH_BONUS                 // 매칭 보너스 (예: 100% 매칭)
  // RELOAD_BONUS                // 리로드 보너스
}

/**
 * 프로모션 자격 유지 조건
 * 프로모션 자격을 유지하기 위한 조건
 */
enum PromotionQualification {
  /// 첫 출금까지 - 첫 출금 전까지 자격 유지
  UNTIL_FIRST_WITHDRAWAL
  // 추천 추가 값들:
  // UNTIL_ROLLING_COMPLETE      // 롤링 완료까지
  // NO_CONDITION                // 조건 없음 (자격 유지)
  // TIME_LIMITED                // 시간 제한 (예: 30일)
  // MINIMUM_WAGER                // 최소 베팅 금액 달성까지
}

/**
 * 사용자 프로모션 상태
 * 사용자가 참여한 프로모션의 현재 상태
 */
enum UserPromotionStatus {
  /// 진행 중 - 롤링 진행 중인 상태
  ACTIVE
  /// 롤링 달성 완료 - 롤링 완료하여 출금 가능한 상태
  COMPLETED
  /// 자격 상실 - 출금 등으로 인해 자격이 상실된 상태
  QUALIFICATION_LOST
  /// 기간 만료 - 프로모션 기간이 만료된 상태
  EXPIRED
  /// 실패 - 기타 사유로 실패한 상태
  FAILED
}

/**
 * Session Management Schema
 * 사용자 세션 추적 및 관리를 위한 스키마
 * - HTTP 세션 및 WebSocket 세션 모두 지원
 * - 여러 디바이스 동시 로그인 추적
 * - 세션 생명주기 관리
 */

/**
 * 세션 타입
 * 지원하는 프로토콜/채널별 세션 타입
 */
enum SessionType {
  /// HTTP 세션 (Express Session)
  HTTP
  /// WebSocket 세션 (Socket.io)
  WEBSOCKET
}

/**
 * 세션 상태
 * 세션의 생명주기 상태
 */
enum SessionStatus {
  /// 활성 상태 - 정상적으로 사용 중인 세션
  ACTIVE
  /// 명시적으로 종료된 세션 - 사용자 또는 관리자가 로그아웃하거나 세션을 종료한 경우
  REVOKED
  /// 만료된 세션 - expiresAt 시간이 지나 자동으로 만료된 세션
  EXPIRED
}

/**
 * 사용자 세션 모델
 * 사용자의 활성 세션을 추적하고 관리합니다.
 * - HTTP 세션 및 WebSocket 세션 모두 추적
 * - 여러 디바이스에서의 동시 로그인 지원
 * - 세션 생명주기 관리 (생성, 활성화, 만료, 종료)
 * - 디바이스 정보 및 메타데이터 저장
 */
model UserSession {
  /// 내부 관리용 ID (DB 저장 시 자동 생성)
  id BigInt @id @default(autoincrement())

  /// 비즈니스용 고유 식별자 (CUID2)
  uid String @unique @default(cuid())

  /// 세션 소유자 사용자 ID
  userId BigInt @map("user_id")

  /// 실제 세션 ID (Express session ID 또는 Socket.io socket ID)
  sessionId String @unique @map("session_id")

  /// 세션 타입 (HTTP, WEBSOCKET 등)
  type SessionType

  /// 세션 상태 (ACTIVE, REVOKED, EXPIRED)
  status SessionStatus @default(ACTIVE)

  /// 관리자 세션 여부 (HTTP 세션인 경우 Redis 키 prefix 결정에 사용)
  isAdmin Boolean @default(false) @map("is_admin")

  /// 디바이스 정보
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  isMobile          Boolean? @map("is_mobile")
  deviceName        String?  @map("device_name") /// 예: "iPhone 14 Pro", "Chrome on Windows"
  os                String? /// 예: "iOS 17.0", "Windows 11"
  browser           String? /// 예: "Chrome 120", "Safari 17"

  /// 타임스탬프
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")

  /// 세션 종료 정보
  revokedAt DateTime? @map("revoked_at") /// 세션 종료 시간 (REVOKED 상태일 때)
  revokedBy BigInt?   @map("revoked_by") /// 세션을 종료한 사용자 ID (관리자가 종료한 경우)

  /// 추가 메타데이터 (JSON)
  metadata Json? @default("{}")

  /// 관계
  user          User  @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  revokedByUser User? @relation("RevokedSessions", fields: [revokedBy], references: [id], onDelete: SetNull)

  /// 인덱스
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@index([status, expiresAt])
  @@index([userId, type, status])
  @@index([deviceFingerprint])
  @@index([ipAddress])
  @@index([lastActiveAt])
  /// 복합 인덱스: 활성 세션 조회 최적화
  @@index([userId, status, lastActiveAt])
  /// 복합 인덱스: 만료된 세션 정리 최적화
  @@index([status, expiresAt, createdAt])
  /// 복합 인덱스: 관리자 세션 조회 최적화
  @@index([isAdmin, status])
  /// 테이블명 매핑
  @@map("user_sessions")
}

model Tier {
  id             BigInt  @id @default(autoincrement())
  uid            String  @unique
  priority       Int     @unique // Lower value means lower tier (e.g., 1=Bronze, 2=Silver)
  code           String  @unique // e.g., "BRONZE", "SILVER"
  // requirement_usd: 승급에 필요한 누적 롤링액 (Cumulative Rolling Amount required for upgrade)
  requirementUsd Decimal @map("requirement_usd") @db.Decimal(32, 18)

  // Benefits
  levelUpBonus Decimal @default(0) @map("level_up_bonus") @db.Decimal(32, 18)
  compRate     Decimal @default(0) @map("comp_rate") @db.Decimal(8, 4) // Integrated Comp Rate
  benefits     Json?   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userTiers    UserTier[]
  translations TierTranslation[]
  historyFrom  TierHistory[]     @relation("HistoryFrom")
  historyTo    TierHistory[]     @relation("HistoryTo")

  @@index([priority])
  @@map("tier")
}

model TierTranslation {
  id  BigInt @id @default(autoincrement())
  uid String @unique

  tierId   BigInt   @map("tier_id")
  language Language
  name     String // Display name (e.g., "브론즈", "Bronze")

  tier Tier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([tierId, language])
  @@index([language])
  @@map("tier_translation")
}

model UserTier {
  id     BigInt @id @default(autoincrement())
  uid    String @unique
  userId BigInt @unique @map("user_id")
  tierId BigInt @map("tier_id")

  // 상태 데이터
  cumulativeRollingUsd Decimal @default(0) @map("cumulative_rolling_usd") @db.Decimal(32, 18)

  // 승급/강등 제어
  highestPromotedPriority Int      @default(0) @map("highest_promoted_priority") // 보너스 중복 지급 방지용
  isManualLock            Boolean  @default(false) @map("is_manual_lock") // 관리자 강제 등급 고정
  lastPromotedAt          DateTime @default(now()) @map("last_promoted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  tier Tier @relation(fields: [tierId], references: [id])

  @@index([tierId])
  @@map("user_tier")
}

model TierHistory {
  id     BigInt @id @default(autoincrement())
  uid    String @unique
  userId BigInt @map("user_id")

  fromTierId BigInt?        @map("from_tier_id")
  toTierId   BigInt         @map("to_tier_id")
  changeType TierChangeType @map("change_type") // UPGRADE, DOWNGRADE, MANUAL, INITIAL
  reason     String? // "Rolling requirement met", "Admin manual update"

  // Snapshot data (변경 시점의 데이터 기록)
  rollingAmountSnap Decimal @map("rolling_amount_snap") @db.Decimal(32, 18)

  bonusAmount Decimal? @map("bonus_amount") @db.Decimal(32, 18) // 지급된 승급 보너스 (없으면 null/0)

  changedAt DateTime @default(now()) @map("changed_at")
  changeBy  String?  @map("change_by") // "SYSTEM", "admin_uid"

  user     User  @relation(fields: [userId], references: [id])
  fromTier Tier? @relation("HistoryFrom", fields: [fromTierId], references: [id])
  toTier   Tier  @relation("HistoryTo", fields: [toTierId], references: [id])

  @@index([userId])
  @@index([changedAt])
  @@map("tier_history")
}

enum TierChangeType {
  INITIAL // 초기 등급
  UPGRADE // 승급
  DOWNGRADE // 강등
  MANUAL_UPDATE // 관리자 수동 변경
}
