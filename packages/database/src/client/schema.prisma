model AffiliateCode {
  id           BigInt     @id @default(autoincrement())
  uid          String     @unique
  userId       BigInt
  code         String     @unique
  campaignName String?
  description  String?
  isActive     Boolean    @default(true)
  isDefault    Boolean    @default(false)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastUsedAt   DateTime?
  user         User       @relation("AffiliateCodes", fields: [userId], references: [id], onDelete: Cascade)
  referrals    Referral[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([code])
}

model Referral {
  id                BigInt        @id @default(autoincrement())
  uid               String        @unique
  affiliateId       BigInt
  subUserId         BigInt
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  codeId            BigInt
  affiliate         User          @relation("AffiliateReferrals", fields: [affiliateId], references: [id], onDelete: Cascade)
  code              AffiliateCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  subUser           User          @relation("ReferredUsers", fields: [subUserId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, subUserId])
  @@index([affiliateId])
  @@index([codeId])
  @@index([subUserId])
  @@index([affiliateId, codeId])
  @@index([ipAddress, deviceFingerprint])
}

// 1. 보안/인증 로그
model AuthAuditLog {
  id                String   @default(cuid())
  createdAt         DateTime @default(now()) @map("created_at")
  userId            BigInt?  @map("user_id")
  sessionId         String?  @map("session_id")
  action            String
  status            String
  ip                String?
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  // Cloudflare 지리적 정보 (보안 분석용)
  country           String? // CF-IPCountry: 비정상적인 위치 감지
  city              String? // CF-IPCity
  // Cloudflare 보안 정보
  bot               Boolean? // CF-Bot-Management: 봇 공격 감지
  threat            String? // CF-Threat: 위협 점수
  // 디바이스 정보
  isMobile          Boolean? @map("is_mobile") // 모바일 여부
  // Cloudflare 추적 정보 (디버깅용)
  cfRay             String?  @map("cf_ray") // CF-Ray: 요청 추적 ID
  metadata          Json?

  @@id([id, createdAt])
  // 보안 추적은 보통 '누가' 했는지와 '언제' 했는지가 결합됩니다.
  @@index([userId, createdAt(sort: Desc)])
  // 세션별 활동 추적
  @@index([sessionId, createdAt(sort: Desc)])
  // 비정상적인 위치에서의 로그인 시도 감지
  @@index([country, createdAt(sort: Desc)])
  // 봇 공격 감지
  @@index([bot, createdAt(sort: Desc)])
  // 위협 점수 기반 필터링
  @@index([threat, createdAt(sort: Desc)])
  @@map("auth_audit_logs")
}

// 2. 서비스 활동 로그
model ActivityLog {
  id        String   @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  userId    BigInt?  @map("user_id")
  sessionId String?  @map("session_id")
  category  String
  action    String
  // Cloudflare 지리적 정보 (사용자 활동 추적용)
  country   String? // CF-IPCountry
  city      String? // CF-IPCity
  // 디바이스 정보
  isMobile  Boolean? @map("is_mobile") // 모바일 여부
  // Cloudflare 추적 정보 (디버깅용)
  cfRay     String?  @map("cf_ray") // CF-Ray: 요청 추적 ID
  metadata  Json?

  @@id([id, createdAt])
  // CS 조회를 위해 userId와 category를 결합한 인덱스 최적화
  @@index([userId, category, createdAt(sort: Desc)])
  // 세션별 활동 추적
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([category, action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  // 지역별 활동 분석
  @@index([country, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// 3. 기술적 문제 로그
model SystemErrorLog {
  id           String    @default(cuid())
  createdAt    DateTime  @default(now()) @map("created_at")
  userId       BigInt?   @map("user_id")
  sessionId    String?   @map("session_id")
  errorCode    String?   @map("error_code")
  errorMessage String    @map("error_message")
  stackTrace   String?   @map("stack_trace") @db.Text
  metadata     Json? // 에러 당시 Request/Session 스냅샷용 추가
  path         String?
  method       String?
  statusCode   Int?      @map("status_code")
  severity     String? // INFO, WARN, ERROR, CRITICAL
  resolved     Boolean   @default(false)
  resolvedAt   DateTime? @map("resolved_at")
  // Cloudflare 지리적 정보 (에러 발생 위치 추적용)
  country      String? // CF-IPCountry
  city         String? // CF-IPCity
  // Cloudflare 보안 정보 (공격성 에러 감지용)
  bot          Boolean? // CF-Bot-Management
  threat       String? // CF-Threat
  // 디바이스 정보
  isMobile     Boolean?  @map("is_mobile") // 모바일 여부
  // Cloudflare 추적 정보 (디버깅용)
  cfRay        String?   @map("cf_ray") // CF-Ray: 요청 추적 ID
  ip           String? // 클라이언트 IP
  userAgent    String?   @map("user_agent") // User-Agent

  @@id([id, createdAt])
  // 에러 관리는 severity와 resolved 상태를 먼저 필터링함
  @@index([severity, resolved, createdAt(sort: Desc)])
  @@index([errorCode, createdAt(sort: Desc)])
  // 세션별 에러 추적
  @@index([sessionId, createdAt(sort: Desc)])
  // 지역별 에러 분석
  @@index([country, createdAt(sort: Desc)])
  // 봇 공격으로 인한 에러 감지
  @@index([bot, createdAt(sort: Desc)])
  @@map("system_error_logs")
}

// 4. 외부 서비스 연동 기록
model IntegrationLog {
  id           String   @default(cuid())
  createdAt    DateTime @default(now()) @map("created_at")
  userId       BigInt?  @map("user_id")
  sessionId    String?  @map("session_id")
  provider     String
  method       String
  endpoint     String
  statusCode   Int?     @map("status_code")
  requestBody  Json?    @map("request_body")
  responseBody Json?    @map("response_body")
  duration     Int
  success      Boolean
  errorMessage String?  @map("error_message")
  // Cloudflare 지리적 정보 (외부 서비스 연동 추적용)
  country      String? // CF-IPCountry
  city         String? // CF-IPCity
  // Cloudflare 보안 정보 (공격성 요청 감지용)
  bot          Boolean? // CF-Bot-Management
  threat       String? // CF-Threat
  // Cloudflare 추적 정보 (디버깅용)
  cfRay        String?  @map("cf_ray") // CF-Ray: 요청 추적 ID
  ip           String? // 클라이언트 IP

  @@id([id, createdAt])
  // 정산 및 장애 대조를 위해 provider와 success를 결합
  @@index([provider, success, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  // 세션별 연동 추적
  @@index([sessionId, createdAt(sort: Desc)])
  // 지역별 연동 분석
  @@index([country, createdAt(sort: Desc)])
  @@map("integration_logs")
}

/// @view
model UnifiedLog {
  id        String   @id
  createdAt DateTime @map("created_at")
  userId    BigInt?  @map("user_id")
  sessionId String?  @map("session_id")
  cfRay     String?  @map("cf_ray")
  country   String?
  city      String?
  bot       Boolean?
  threat    String?
  isMobile  Boolean? @map("is_mobile")
  ip        String?

  // 구분자 필드
  logType  String @map("log_type") // AUTH, ACTIVITY, ERROR, INTEGRATION
  category String // 각 테이블의 주요 분류
  detail   String // 주요 내용 (상태, 액션, 에러메시지 등)
  metadata Json?

  @@map("unified_logs")
}

generator client {
  provider     = "prisma-client-js"
  output       = "../../src/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   BigInt                @id @default(autoincrement())
  uid                  String                @unique @default(cuid())
  whitecliffId         BigInt?               @unique
  whitecliffSystemId   BigInt?               @unique
  whitecliffUsername   String?               @unique
  dcsId                String?               @unique
  email                String?               @unique
  passwordHash         String?
  socialType           SocialType?
  socialId             String?
  role                 UserRoleType          @default(USER)
  status               UserStatus            @default(ACTIVE)
  kycLevel             KycLevel              @default(NONE)
  country              String?
  language             Language?
  timezone             String?
  timezoneOffset       Int?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  affiliateCodes       AffiliateCode[]       @relation("AffiliateCodes")
  affiliateCommissions AffiliateCommission[] @relation("AffiliateCommissions")
  subUserCommissions   AffiliateCommission[] @relation("SubUserCommissions")
  affiliateTier        AffiliateTier?
  affiliateWallets     AffiliateWallet[]     @relation("AffiliateWallets")
  CompTransaction      CompTransaction[]
  DailyCompEarning     DailyCompEarning[]
  EmailLog             EmailLog[]
  GameSession          GameSession[]
  affiliateReferrals   Referral[]            @relation("AffiliateReferrals")
  referredUsers        Referral[]            @relation("ReferredUsers")
  Rolling              Rolling[]
  transactions         Transaction[]
  depositDetails       DepositDetail[]
  balances             UserBalance[]
  UserBalanceStats     UserBalanceStats[]
  UserPromotion        UserPromotion[]
  UserSession          UserSession[]         @relation("UserSessions")
  RevokedSessions      UserSession[]         @relation("RevokedSessions")
  UserToken            UserToken[]
  loginAttempts        LoginAttempt[]
  userTier             UserTier?
  tierHistory          TierHistory[]
}

model UserBalance {
  userId       BigInt
  currency     ExchangeCurrencyCode
  mainBalance  Decimal              @default(0) @db.Decimal(32, 18)
  bonusBalance Decimal              @default(0) @db.Decimal(32, 18)
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id])

  @@id([userId, currency])
  @@index([userId])
  @@index([currency])
}

model UserBalanceStats {
  userId                 BigInt
  currency               ExchangeCurrencyCode
  totalDeposit           Decimal              @default(0) @db.Decimal(32, 18)
  totalWithdraw          Decimal              @default(0) @db.Decimal(32, 18)
  totalBet               Decimal              @default(0) @db.Decimal(32, 18)
  totalWin               Decimal              @default(0) @db.Decimal(32, 18)
  totalBonus             Decimal              @default(0) @db.Decimal(32, 18)
  totalCompEarned        Decimal              @default(0) @db.Decimal(32, 18)
  totalCompUsed          Decimal              @default(0) @db.Decimal(32, 18)
  totalSettlementFromBet Decimal              @default(0) @db.Decimal(32, 18)
  totalSettlementFromVip Decimal              @default(0) @db.Decimal(32, 18)
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id])

  @@id([userId, currency])
  @@index([userId])
  @@index([currency])
}

model Game {
  id               Int                @id @default(autoincrement())
  aggregatorType   GameAggregatorType
  provider         GameProvider
  category         GameCategory
  gameId           Int
  gameType         String?
  tableId          String?
  iconLink         String?
  isEnabled        Boolean
  isVisibleToUser  Boolean            @default(true)
  houseEdge        Decimal            @default(0.04) @db.Decimal(8, 4)
  contributionRate Decimal            @default(1.0) @db.Decimal(8, 4)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  bonusDetails     BonusDetail[]
  gameRounds       GameRound[]
  gameSessions     GameSession[]
  translations     GameTranslation[]

  @@unique([aggregatorType, provider, gameId])
  @@index([isEnabled])
}

model GameTranslation {
  id           Int      @id @default(autoincrement())
  gameId       Int
  language     Language
  providerName String
  categoryName String
  gameName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, language])
  @@index([language])
}

model Transaction {
  id              BigInt                     @id @default(autoincrement())
  userId          BigInt
  type            TransactionType
  status          TransactionStatus
  currency        ExchangeCurrencyCode
  amount          Decimal                    @db.Decimal(32, 18)
  beforeAmount    Decimal                    @db.Decimal(32, 18)
  afterAmount     Decimal                    @db.Decimal(32, 18)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  bonusDetail     BonusDetail?
  compTransaction CompTransaction?
  depositDetail   DepositDetail?
  gameRound       GameRound?
  user            User                       @relation(fields: [userId], references: [id])
  balanceDetails  TransactionBalanceDetail[]
  withdrawDetail  WithdrawDetail?
}

model GameRound {
  id                             BigInt                @id @default(autoincrement())
  userId                         BigInt
  aggregatorType                 GameAggregatorType
  provider                       GameProvider
  aggregatorTxId                 String
  aggregatorGameId               Int
  totalBetAmountInGameCurrency   Decimal?              @db.Decimal(32, 18)
  totalWinAmountInGameCurrency   Decimal?              @db.Decimal(32, 18)
  netAmountInGameCurrency        Decimal?              @db.Decimal(32, 18)
  totalBetAmountInWalletCurrency Decimal?              @db.Decimal(32, 18)
  totalWinAmountInWalletCurrency Decimal?              @db.Decimal(32, 18)
  netAmountInWalletCurrency      Decimal?              @db.Decimal(32, 18)
  transactionId                  BigInt                @unique
  sessionId                      String?
  tableId                        String?
  roundId                        String?
  replayType                     GameReplayType?
  replayData                     String?
  totalPushAmount                Decimal?              @db.Decimal(32, 18)
  tieBetAmount                   Decimal?              @db.Decimal(32, 18)
  contributionAmount             Decimal?              @db.Decimal(32, 18)
  compEarned                     Decimal?              @db.Decimal(32, 18)
  jackpotContributionAmount      Decimal               @default(0) @db.Decimal(32, 18)
  startedAt                      DateTime?
  completedAt                    DateTime?
  gameId                         Int?
  gameSessionId                  BigInt
  AffiliateCommission            AffiliateCommission[]
  bets                           GameBet[]
  game                           Game?                 @relation(fields: [gameId], references: [id])
  GameSession                    GameSession           @relation(fields: [gameSessionId], references: [id])
  transaction                    Transaction           @relation(fields: [transactionId], references: [id])
  wins                           GameWin[]

  @@unique([aggregatorTxId, aggregatorType])
}

model GameBet {
  id                      BigInt             @id @default(autoincrement())
  userId                  BigInt
  gameRoundId             BigInt
  aggregatorType          GameAggregatorType
  aggregatorBetId         String
  betType                 BetType
  betAmount               Decimal            @db.Decimal(32, 18)
  bettedAt                DateTime
  betAmountInGameCurrency Decimal            @db.Decimal(32, 18)
  createdAt               DateTime           @default(now())
  isCancelled             Boolean            @default(false)
  cancelledAt             DateTime?
  gameRound               GameRound          @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  @@unique([aggregatorBetId, aggregatorType])
  @@index([gameRoundId])
}

model GameWin {
  id                      BigInt             @id @default(autoincrement())
  userId                  BigInt
  gameRoundId             BigInt
  aggregatorType          GameAggregatorType
  aggregatorWinId         String
  winType                 WinType
  winAmount               Decimal            @db.Decimal(32, 18)
  wonAt                   DateTime
  description             String?
  winAmountInGameCurrency Decimal            @db.Decimal(32, 18)
  createdAt               DateTime           @default(now())
  gameRound               GameRound          @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  @@unique([aggregatorWinId, aggregatorType])
  @@index([gameRoundId])
}

model TransactionBalanceDetail {
  id                 BigInt      @id @default(autoincrement())
  transactionId      BigInt
  mainBalanceChange  Decimal?    @db.Decimal(32, 18)
  mainBeforeAmount   Decimal?    @db.Decimal(32, 18)
  mainAfterAmount    Decimal?    @db.Decimal(32, 18)
  bonusBalanceChange Decimal?    @db.Decimal(32, 18)
  bonusBeforeAmount  Decimal?    @db.Decimal(32, 18)
  bonusAfterAmount   Decimal?    @db.Decimal(32, 18)
  createdAt          DateTime    @default(now())
  transaction        Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

model BonusDetail {
  id                      BigInt             @id @default(autoincrement())
  createdAt               DateTime           @default(now())
  transactionTime         DateTime
  aggregatorType          GameAggregatorType
  provider                GameProvider
  bonusType               BonusType
  amount                  Decimal            @db.Decimal(32, 18)
  aggregatorPromotionId   String?
  aggregatorRoundId       String?
  aggregatorWagerId       String?
  aggregatorTransactionId String?
  aggregatorFreespinId    String?
  aggregatorSessionId     String?
  isEndRound              Boolean?
  description             String?
  gameId                  Int?
  transactionId           BigInt             @unique
  game                    Game?              @relation(fields: [gameId], references: [id])
  transaction             Transaction        @relation(fields: [transactionId], references: [id])
}

model WithdrawDetail {
  id                   BigInt               @id @default(autoincrement())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  status               WithdrawDetailStatus
  transactionId        BigInt               @unique
  withdrawCurrency     ExchangeCurrencyCode
  withdrawNetwork      String
  withdrawAmount       Decimal              @db.Decimal(32, 18)
  walletAddress        String
  walletAddressExtraId String?
  provider             PaymentProvider
  providerWithdrawalId String?              @unique
  transactionHash      String?
  errorMessage         String?
  feeAmount            Decimal?             @db.Decimal(32, 18)
  feeCurrency          String?
  feePaidBy            FeePaidByType?
  providerMetadata     Json?                @default("{}")
  transaction          Transaction          @relation(fields: [transactionId], references: [id])

  @@index([provider, providerWithdrawalId])
  @@index([provider, status])
  @@index([transactionHash])
  @@index([status, createdAt])
}

model CompTransaction {
  id                 BigInt           @id @default(autoincrement())
  userId             BigInt
  amount             Decimal          @db.Decimal(32, 18)
  dailyCompEarningId Int
  transactionId      BigInt           @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  dailyCompEarning   DailyCompEarning @relation(fields: [dailyCompEarningId], references: [id])
  transaction        Transaction      @relation(fields: [transactionId], references: [id])
  user               User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model DailyCompEarning {
  id                Int               @id @default(autoincrement())
  userId            BigInt
  earningDate       DateTime
  totalContribution Decimal           @db.Decimal(32, 18)
  compEarned        Decimal           @db.Decimal(32, 18)
  isProcessed       Boolean           @default(false)
  processedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  CompTransaction   CompTransaction[]
  user              User              @relation(fields: [userId], references: [id])

  @@unique([userId, earningDate])
  @@index([earningDate])
  @@index([isProcessed])
}

model NowPaymentCallbackLog {
  id              BigInt    @id @default(autoincrement())
  requestHeaders  Json?
  requestBody     Json
  responseStatus  Int?
  responseBody    Json?
  processed       Boolean   @default(false)
  processingError String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
}

model ExchangeRate {
  id            Int                  @id @default(autoincrement())
  baseCurrency  ExchangeCurrencyCode
  quoteCurrency ExchangeCurrencyCode
  rate          Decimal              @db.Decimal(32, 18)
  provider      ExchangeRateProvider
  collectedAt   DateTime             @default(now())
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  previousRate  Decimal?             @db.Decimal(32, 18)
  changeRate    Decimal?             @db.Decimal(8, 4)
  isValid       Boolean              @default(true)

  @@unique([baseCurrency, quoteCurrency, provider])
  @@index([baseCurrency, quoteCurrency])
  @@index([baseCurrency, quoteCurrency, provider])
  @@index([collectedAt])
  @@index([isActive, collectedAt])
}

model Rolling {
  id                           BigInt            @id @default(autoincrement())
  userId                       BigInt
  sourceType                   RollingSourceType @default(DEPOSIT)
  userPromotionId              BigInt?
  requiredAmount               Decimal           @db.Decimal(32, 18)
  currentAmount                Decimal           @default(0) @db.Decimal(32, 18)
  cancellationBalanceThreshold Decimal?          @db.Decimal(32, 18)
  status                       RollingStatus     @default(ACTIVE)
  depositAmount                Decimal?          @db.Decimal(32, 18)
  bonusAmount                  Decimal?          @db.Decimal(32, 18)
  completedAt                  DateTime?
  cancelledAt                  DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
  depositDetailId              BigInt?
  DepositDetail                DepositDetail?    @relation(fields: [depositDetailId], references: [id])
  user                         User              @relation(fields: [userId], references: [id])
  userPromotion                UserPromotion?    @relation(fields: [userPromotionId], references: [id])

  @@index([userId, status, createdAt])
  @@index([sourceType])
  @@index([userPromotionId])
  @@index([status])
}

model UserToken {
  id        Int       @id @default(autoincrement())
  userId    BigInt
  type      TokenType
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([type, expiresAt])
  @@index([userId, type, usedAt])
  @@index([expiresAt])
}

model EmailLog {
  id        Int         @id @default(autoincrement())
  userId    BigInt?
  type      EmailType
  status    EmailStatus
  to        String
  subject   String
  from      String?
  messageId String?
  error     String?
  metadata  Json?       @default("{}")
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId, type, createdAt])
  @@index([to, type, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
}

model GameSession {
  id                     BigInt               @id @default(autoincrement())
  userId                 BigInt
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  lastAccessedAt         DateTime             @default(now())
  aggregatorType         GameAggregatorType
  token                  String               @unique
  walletCurrency         ExchangeCurrencyCode
  gameCurrency           ExchangeCurrencyCode
  exchangeRate           Decimal              @db.Decimal(32, 18)
  exchangeRateSnapshotAt DateTime             @default(now())
  gameId                 Int?
  gameRounds             GameRound[]
  game                   Game?                @relation(fields: [gameId], references: [id])
  user                   User                 @relation(fields: [userId], references: [id])
}

model AffiliateWallet {
  affiliateId      BigInt
  currency         ExchangeCurrencyCode
  availableBalance Decimal              @default(0) @db.Decimal(32, 18)
  pendingBalance   Decimal              @default(0) @db.Decimal(32, 18)
  totalEarned      Decimal              @default(0) @db.Decimal(32, 18)
  updatedAt        DateTime             @updatedAt
  affiliate        User                 @relation("AffiliateWallets", fields: [affiliateId], references: [id], onDelete: Cascade)

  @@id([affiliateId, currency])
  @@index([affiliateId])
  @@index([currency])
}

model AffiliateCommission {
  affiliateId    BigInt
  subUserId      BigInt
  gameRoundId    BigInt?
  wagerAmount    Decimal              @db.Decimal(32, 18)
  winAmount      Decimal?             @db.Decimal(32, 18)
  commission     Decimal              @db.Decimal(32, 18)
  rateApplied    Decimal              @db.Decimal(8, 4)
  currency       ExchangeCurrencyCode
  status         CommissionStatus     @default(PENDING)
  gameCategory   GameCategory?
  /// settlementDate: PENDING → AVAILABLE 전환 시점 (월간 정산일)
  /// claimedAt: AVAILABLE → CLAIMED 전환 시점 (출금 요청 시점)
  /// withdrawnAt: CLAIMED → WITHDRAWN 전환 시점 (출금 처리 완료 시점)
  settlementDate DateTime?
  claimedAt      DateTime?
  withdrawnAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  uid            String               @unique
  id             BigInt               @id @default(autoincrement())
  affiliate      User                 @relation("AffiliateCommissions", fields: [affiliateId], references: [id], onDelete: Cascade)
  gameRound      GameRound?           @relation(fields: [gameRoundId], references: [id])
  subUser        User                 @relation("SubUserCommissions", fields: [subUserId], references: [id], onDelete: Cascade)

  @@index([affiliateId, status])
  @@index([affiliateId, createdAt])
  @@index([subUserId])
  @@index([status, createdAt])
  @@index([settlementDate])
  @@index([gameRoundId])
}

model AffiliateTier {
  affiliateId        BigInt             @unique
  tier               AffiliateTierLevel @default(BRONZE)
  baseRate           Decimal            @db.Decimal(8, 4)
  customRate         Decimal?           @db.Decimal(8, 4)
  isCustomRate       Boolean            @default(false)
  monthlyWagerAmount Decimal            @default(0) @db.Decimal(32, 18)
  customRateSetBy    String?
  customRateSetAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  uid                String             @unique
  id                 BigInt             @id @default(autoincrement())
  affiliate          User               @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([tier])
}

