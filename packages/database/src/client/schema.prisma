model Referral {
  id                String        @id @default(cuid())
  affiliateId       BigInt
  subUserId         BigInt
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  codeId            String
