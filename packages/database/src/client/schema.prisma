  messageId String?
  error     String?
  metadata  Json?       @default("{}")
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId, type, createdAt])
  @@index([to, type, createdAt])
  @@index([status, createdAt])
