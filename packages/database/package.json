{
    "name": "@repo/database",
    "version": "0.0.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "prisma": "dotenv -e ../../.env -- prisma",
        "clean:client": "rm -rf src/client",
        "generate": "pnpm clean:client && pnpm prisma generate",
        "migrate": "pnpm clean:client && pnpm prisma migrate dev && pnpm prisma generate",
        "format": "pnpm prisma format",
        "reset": "pnpm prisma migrate reset",
        "deploy": "pnpm clean:client && pnpm prisma migrate deploy && pnpm prisma generate",
        "seed": "pnpm prisma db seed",
        "studio": "pnpm prisma studio"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.2.0",
        "@prisma/client": "^7.2.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/node": "^25.0.3",
        "bcryptjs": "^3.0.3",
        "prisma": "^7.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}