/**
 * 입금 관련 스키마
 * 입금 상세 정보 및 입금 방법, 상태 관리
 */

/**
 * 입금 상세 정보 모델
 * 사용자의 입금 요청 및 처리 상태를 추적합니다.
 * - 암호화폐 지갑 입금 및 계좌 이체 입금 지원
 * - 입금 상태 추적 (대기, 확인 중, 완료, 실패 등)
 * - 프로바이더별 입금 정보 관리
 * - 신청 금액과 실제 입금 금액 분리 추적
 * - 관리자 수동 처리 추적 (MANUAL 프로바이더용)
 * - 보안 및 어뷰징 방지 (핵심 정보만 저장, 상세 정보는 ActivityLog 참조)
 * - 수수료 및 실제 입금 금액 추적
 */
model DepositDetail {
  id                   BigInt               @id @default(autoincrement())
  uid                  String               @unique
  confirmedAt          DateTime?            @map("confirmed_at")
  failedAt             DateTime?            @map("failed_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  status               DepositDetailStatus
  transactionId        BigInt               @unique @map("transaction_id")
  methodType           DepositMethodType    @map("method_type")
  provider             PaymentProvider
  providerPaymentId    String?              @unique @map("provider_payment_id")
  depositCurrency      ExchangeCurrencyCode @map("deposit_currency")
  depositNetwork       String?              @map("deposit_network")
  walletAddress        String?              @map("wallet_address")
  walletAddressExtraId String?              @map("wallet_address_extra_id")
  depositorName        String?              @map("depositor_name")
  transactionHash      String?              @map("transaction_hash")

  // 1. 신청 금액과 실입금 금액의 분리
  requestedAmount Decimal  @map("requested_amount") @db.Decimal(32, 18)
  actuallyPaid    Decimal? @map("actually_paid") @db.Decimal(32, 18)

  // 2. 관리자 수동 처리 추적 (MANUAL 프로바이더용)
  processedBy BigInt? @map("processed_by")
  adminNote   String? @map("admin_note") @db.Text

  // 3. 보안 및 어뷰징 방지
  // 상세 보안 정보는 ActivityLog에 기록되며, 여기서는 최소한의 핵심 정보만 저장
  // 어뷰징 체크 시 ActivityLog와 join하여 조회
  ipAddress         String? @map("ip_address")
  deviceFingerprint String? @map("device_fingerprint")

  feeAmount        Decimal?       @map("fee_amount") @db.Decimal(32, 18)
  feeCurrency      String?        @map("fee_currency")
  feePaidBy        FeePaidByType? @map("fee_paid_by")
  failureReason    String?        @map("failure_reason")
  providerMetadata Json?          @default("{}") @map("provider_metadata")
  bankConfigId     BigInt?        @map("bank_config_id")
  cryptoConfigId   BigInt?        @map("crypto_config_id")
  BankConfig       BankConfig?    @relation(fields: [bankConfigId], references: [id])
  CryptoConfig     CryptoConfig?  @relation(fields: [cryptoConfigId], references: [id])
  transaction      Transaction    @relation(fields: [transactionId], references: [id])
  Rolling          Rolling[]

  @@index([provider, providerPaymentId])
  @@index([status, createdAt])
  @@index([transactionId])
  @@index([methodType, status])
  @@index([depositCurrency, status])
  @@index([createdAt])
  @@index([processedBy])
  @@index([ipAddress, deviceFingerprint])
  @@index([ipAddress])
  @@index([deviceFingerprint])
  @@index([bankConfigId])
  @@index([cryptoConfigId])
  @@map("deposit_details")
}

/**
 * 입금 방법 타입
 * 지원하는 입금 방법 유형
 */
enum DepositMethodType {
  /// 암호화폐 지갑 입금 - 암호화폐를 지갑 주소로 입금
  CRYPTO_WALLET
  /// 계좌 이체 입금 - 은행 계좌로 입금
  BANK_TRANSFER
}

/**
 * 입금 상세 상태
 * 입금 요청의 처리 상태
 */
enum DepositDetailStatus {
  /// 대기 중 - 입금 요청이 생성되어 처리 대기 중
  PENDING
  /// 확인 중 - 입금이 확인되는 중 (블록체인 확인 등)
  CONFIRMING
  /// 완료 - 입금이 성공적으로 완료됨
  COMPLETED
  /// 실패 - 입금 처리 중 오류 발생
  FAILED
  /// 취소됨 - 입금 요청이 취소됨
  CANCELLED
  /// 만료됨 - 입금 요청이 만료됨
  EXPIRED
  /// 거부됨 - 관리자가 입금을 거부함
  REJECTED
}

/**
 * 결제 프로바이더
 * 입금 및 출금에 사용되는 결제 프로바이더
 */
enum PaymentProvider {
  /// NowPayment - 외부 결제 프로바이더
  NOWPAYMENT
  /// 수동 처리 - 관리자가 수동으로 처리하는 입출금
  MANUAL
}

/**
 * 수수료 부담 주체
 * 입금 및 출금 시 수수료를 부담하는 주체
 */
enum FeePaidByType {
  /// 사용자 부담 - 수수료를 사용자가 부담
  USER
  /// 시스템 부담 - 수수료를 시스템이 부담
  SYSTEM
}

/**
 * 암호화폐 입금 설정 모델
 * 암호화폐별 입금 설정을 관리합니다.
 * - symbol과 network 조합으로 고유하게 관리
 * - 최소 입금 금액, 수수료율, 승인 필요 블록 수 등 설정
 * - 토큰의 경우 contractAddress 저장
 */
model CryptoConfig {
  id               BigInt          @id @default(autoincrement())
  uid              String          @unique
  symbol           String // BTC, ETH, USDT 등
  network          String // Mainnet, ERC20, TRC20 등
  isActive         Boolean         @default(true)
  minDepositAmount Decimal         @map("min_deposit_amount") @db.Decimal(32, 18)
  depositFeeRate   Decimal         @default(0) @map("deposit_fee_rate") @db.Decimal(8, 4) // 입금 수수료율 (예: 0.001 = 0.1%)
  confirmations    Int             @default(3) // 승인 필요한 블록 수
  contractAddress  String?         @map("contract_address") // 토큰일 경우 컨트랙트 주소
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")
  depositDetails   DepositDetail[]

  @@unique([symbol, network])
  @@index([symbol, network, isActive])
  @@index([isActive])
  @@map("crypto_configs")
}

/**
 * 은행 계좌 입금 설정 모델
 * 은행 계좌별 입금 설정 및 계좌 정보를 관리합니다.
 * - 은행 계좌 정보 (은행명, 계좌번호, 예금주 등)
 * - 입금 설정 (최소/최대 금액, 우선순위 등)
 * - 통계 정보 (총 입금 횟수, 총 입금 금액)
 * - 소프트 삭제 지원
 */
model BankConfig {
  id                 BigInt               @id @default(autoincrement())
  uid                String               @unique
  currency           ExchangeCurrencyCode
  bankName           String               @map("bank_name")
  accountNumber      String               @map("account_number")
  accountHolder      String               @map("account_holder")
  isActive           Boolean              @default(true) @map("is_active")
  priority           Int                  @default(0)
  description        String?              @db.Text // 유저에게 보여줄 안내 사항 (예: "반드시 본인 성함으로 입금")
  notes              String?              @db.Text // 관리자용 메모
  minAmount          Decimal              @map("min_amount") @db.Decimal(32, 18)
  maxAmount          Decimal?             @map("max_amount") @db.Decimal(32, 18) // null이면 제한 없음
  totalDeposits      Int                  @default(0) @map("total_deposits")
  totalDepositAmount Decimal              @default(0) @map("total_deposit_amount") @db.Decimal(32, 18)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")
  depositDetails     DepositDetail[]

  @@index([currency, isActive, priority])
  @@index([isActive])
  @@index([currency])
  @@index([priority])
  @@index([deletedAt])
  @@map("bank_configs")
}
