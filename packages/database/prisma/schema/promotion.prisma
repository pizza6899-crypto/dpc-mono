model Promotion {
  id                             BigInt                 @id @default(autoincrement())
  managementName                 String                 @map("management_name")
  isActive                       Boolean                @default(true) @map("is_active")
  startDate                      DateTime?              @map("start_date")
  endDate                        DateTime?              @map("end_date")
  deletedAt                      DateTime?              @map("deleted_at")
  targetType                     PromotionTargetType    @map("target_type")
  bonusType                      PromotionBonusType     @map("bonus_type")
  bonusRate                      Decimal?               @map("bonus_rate") @db.Decimal(8, 4)
  code                           String                 @unique @map("code")
  rollingMultiplier              Decimal?               @map("rolling_multiplier") @db.Decimal(8, 4)
  qualificationMaintainCondition PromotionQualification @map("qualification_maintain_condition")
  isOneTime                      Boolean                @default(false) @map("is_one_time")
  createdAt                      DateTime               @default(now()) @map("created_at")
  updatedAt                      DateTime               @updatedAt @map("updated_at")
  translations                   PromotionTranslation[]
  currencies                     PromotionCurrency[]
  UserPromotion                  UserPromotion[]
  depositDetails                 DepositDetail[]

  @@map("promotions")
}

model PromotionTranslation {
  id          BigInt    @id @default(autoincrement())
  promotionId BigInt    @map("promotion_id")
  language    Language
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, language])
  @@index([language])
  @@index([promotionId])
  @@map("promotion_translations")
}

model PromotionCurrency {
  id               BigInt               @id @default(autoincrement())
  promotionId      BigInt               @map("promotion_id")
  currency         ExchangeCurrencyCode
  minDepositAmount Decimal              @map("min_deposit_amount") @db.Decimal(32, 18)
  maxBonusAmount   Decimal?             @map("max_bonus_amount") @db.Decimal(32, 18)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  promotion        Promotion            @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, currency])
  @@index([promotionId])
  @@index([currency])
  @@map("promotion_currencies")
}

model UserPromotion {
  id                   BigInt                @id @default(autoincrement())
  userId               BigInt                @map("user_id")
  promotionId          BigInt                @map("promotion_id")
  status               UserPromotionStatus   @default(ACTIVE)
  depositAmount        Decimal               @map("deposit_amount") @db.Decimal(32, 18)
  bonusAmount          Decimal               @map("bonus_amount") @db.Decimal(32, 18)
  targetRollingAmount  Decimal               @map("target_rolling_amount") @db.Decimal(32, 18)
  currentRollingAmount Decimal               @default(0) @map("current_rolling_amount") @db.Decimal(32, 18)
  currency             ExchangeCurrencyCode
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  wageringRequirements WageringRequirement[]
  promotion            Promotion             @relation(fields: [promotionId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("user_promotions")
}

/**
 * 프로모션 타겟 타입
 * 프로모션이 적용되는 대상 사용자 유형
 */
enum PromotionTargetType {
  /// 신규 유저 첫 입금 - 신규 가입 후 첫 입금 시 적용
  NEW_USER_FIRST_DEPOSIT
  // 추천 추가 값들:
  // EXISTING_USER_DEPOSIT      // 기존 유저 입금
  // WEEKLY_DEPOSIT              // 주간 입금 프로모션
  // MONTHLY_DEPOSIT             // 월간 입금 프로모션
  // BIRTHDAY                    // 생일 프로모션
  // VIP_LEVEL_UP                // VIP 레벨업 프로모션
  // REFERRAL_BONUS              // 추천인 보너스
  // LOYALTY_REWARD              // 로열티 보상
}

/**
 * 프로모션 보너스 타입
 * 보너스 지급 방식
 */
enum PromotionBonusType {
  /// 퍼센트 기반 보너스 - 입금 금액의 일정 비율로 지급
  PERCENTAGE
  /// 고정 금액 보너스 - 입금 금액과 무관하게 고정 금액 지급
  FIXED_AMOUNT
  // 추천 추가 값들:
  // FREE_SPINS                  // 무료 스핀
  // CASHBACK                    // 캐시백
  // MATCH_BONUS                 // 매칭 보너스 (예: 100% 매칭)
  // RELOAD_BONUS                // 리로드 보너스
}

/**
 * 프로모션 자격 유지 조건
 * 프로모션 자격을 유지하기 위한 조건
 */
enum PromotionQualification {
  /// 첫 출금까지 - 첫 출금 전까지 자격 유지
  UNTIL_FIRST_WITHDRAWAL
  // 추천 추가 값들:
  // UNTIL_ROLLING_COMPLETE      // 롤링 완료까지
  // NO_CONDITION                // 조건 없음 (자격 유지)
  // TIME_LIMITED                // 시간 제한 (예: 30일)
  // MINIMUM_WAGER                // 최소 베팅 금액 달성까지
}

/**
 * 사용자 프로모션 상태
 * 사용자가 참여한 프로모션의 현재 상태
 */
enum UserPromotionStatus {
  /// 진행 중 - 롤링 진행 중인 상태
  ACTIVE
  /// 롤링 달성 완료 - 롤링 완료하여 출금 가능한 상태
  COMPLETED
  /// 자격 상실 - 출금 등으로 인해 자격이 상실된 상태
  QUALIFICATION_LOST
  /// 기간 만료 - 프로모션 기간이 만료된 상태
  EXPIRED
  /// 실패 - 기타 사유로 실패한 상태
  FAILED
}
