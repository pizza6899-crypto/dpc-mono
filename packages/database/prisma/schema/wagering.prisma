model WageringRequirement {
  id         BigInt               @id @default(autoincrement())
  uid        String               @unique @default(cuid())
  userId     BigInt               @map("user_id")
  currency   ExchangeCurrencyCode
  sourceType WageringSourceType   @default(DEPOSIT) @map("source_type")

  // 금액 관련
  requiredAmount               Decimal  @map("required_amount") @db.Decimal(32, 18)
  currentAmount                Decimal  @default(0) @map("current_amount") @db.Decimal(32, 18)
  cancellationBalanceThreshold Decimal? @map("cancellation_balance_threshold") @db.Decimal(32, 18)

  // 상태
  status WageringStatus @default(ACTIVE)

  // 링크
  depositDetailId BigInt? @map("deposit_detail_id")
  userPromotionId BigInt? @map("user_promotion_id")

  // 타임스탬프
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  expiresAt        DateTime? @map("expires_at")
  completedAt      DateTime? @map("completed_at")
  cancelledAt      DateTime? @map("cancelled_at")
  cancellationNote String?   @map("cancellation_note")

  // 우선순위 (높을수록 먼저 차감, 예: 기간제 보너스 우선)
  priority Int @default(0)

  // Relations
  depositDetail    DepositDetail?            @relation(fields: [depositDetailId], references: [id])
  userWallet       UserWallet                @relation(fields: [userId, currency], references: [userId, currency])
  userPromotion    UserPromotion?            @relation(fields: [userPromotionId], references: [id])
  user             User                      @relation(fields: [userId], references: [id])
  contributionLogs WageringContributionLog[]

  @@index([userId, currency, status, priority])
  @@index([userId, status])
  @@index([sourceType])
  @@index([userPromotionId])
  @@index([status])
  @@map("wagering_requirements")
}

model WageringContributionLog {
  id                    BigInt @id @default(autoincrement())
  wageringRequirementId BigInt @map("wagering_requirement_id")
  gameRoundId           BigInt @map("game_round_id")

  requestAmount     Decimal @map("request_amount") @db.Decimal(32, 18) // 원래 베팅액
  contributionRate  Decimal @map("contribution_rate") @db.Decimal(8, 4) // 당시 기여도
  contributedAmount Decimal @map("contributed_amount") @db.Decimal(32, 18) // 실제 차감된 금액

  createdAt DateTime @default(now()) @map("created_at")

  wageringRequirement WageringRequirement @relation(fields: [wageringRequirementId], references: [id])

  @@index([wageringRequirementId])
  @@index([gameRoundId])
  @@map("wagering_contribution_logs")
}

enum WageringSourceType {
  DEPOSIT
  PROMOTION_BONUS
}

enum WageringStatus {
  /// 활성 - 롤링 조건을 채워야 함
  ACTIVE
  /// 완료 - 롤링 조건 충족 완료
  COMPLETED
  /// 취소됨 - 잔액 부족(오링)으로 자연 소멸
  CANCELLED
  /// 만료됨 - 기간 만료로 인한 종료 (보너스 회수 대상)
  EXPIRED
  /// 무효화됨 - 관리자 또는 시스템에 의한 강제 취소
  VOIDED
}
