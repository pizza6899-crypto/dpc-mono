// 카테고리 관련 해서 테이블 생성해서 리팩토링 진행할거
// 기존 카지노 게임은 냅두고

// ═══════════════════════════════════════════════════════════════
// 기존 카지노 게임 (Legacy - 유지)
// ═══════════════════════════════════════════════════════════════

model CasinoGame {
  id               BigInt                  @id @default(autoincrement())
  aggregatorType   GameAggregatorType      @map("aggregator_type")
  provider         GameProvider
  category         GameCategory
  gameId           Int                     @map("game_id")
  gameType         String?                 @map("game_type")
  tableId          String?                 @map("table_id")
  iconLink         String?                 @map("icon_link")
  isEnabled        Boolean                 @map("is_enabled")
  isVisibleToUser  Boolean                 @default(true) @map("is_visible_to_user")
  houseEdge        Decimal                 @default(0.04) @map("house_edge") @db.Decimal(8, 4)
  contributionRate Decimal                 @default(1.0) @map("contribution_rate") @db.Decimal(8, 4)
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  bonusDetails     BonusDetail[]
  gameRounds       GameRound[]
  gameSessions     CasinoGameSession[]
  translations     CasinoGameTranslation[]

  @@unique([aggregatorType, provider, gameId])
  @@index([isEnabled])
  @@map("casino_games")
}

model CasinoGameTranslation {
  id           Int        @id @default(autoincrement())
  gameId       BigInt     @map("game_id")
  language     Language
  providerName String     @map("provider_name")
  categoryName String     @map("category_name")
  gameName     String     @map("game_name")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  casinoGame   CasinoGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, language])
  @@index([language])
  @@map("casino_game_translations")
}

model CasinoGameSession {
  id                     BigInt               @id @default(autoincrement())
  uid                    String               @unique
  userId                 BigInt               @map("user_id")
  token                  String               @unique
  playerName             String               @map("player_name")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  lastAccessedAt         DateTime             @default(now()) @map("last_accessed_at")
  aggregatorType         GameAggregatorType   @map("aggregator_type")
  walletCurrency         ExchangeCurrencyCode @map("wallet_currency")
  gameCurrency           ExchangeCurrencyCode @map("game_currency")
  exchangeRate           Decimal              @map("exchange_rate") @db.Decimal(32, 18)
  exchangeRateSnapshotAt DateTime             @default(now()) @map("exchange_rate_snapshot_at")
  usdExchangeRate        Decimal              @map("usd_exchange_rate") @db.Decimal(32, 18)
  compRate               Decimal              @map("comp_rate") @db.Decimal(8, 4)
  casinoGameId           BigInt?              @map("casino_game_id")
  gameRounds             GameRound[]
  casinoGame             CasinoGame?          @relation(fields: [casinoGameId], references: [id])
  user                   User                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("casino_game_sessions")
}

model GameBet {
  id                      BigInt
  userId                  BigInt             @map("user_id")
  gameRoundId             BigInt             @map("game_round_id")
  aggregatorType          GameAggregatorType @map("aggregator_type")
  aggregatorBetId         String             @map("aggregator_bet_id")
  betType                 BetType            @map("bet_type")
  betAmount               Decimal            @map("bet_amount") @db.Decimal(32, 18)
  bettedAt                DateTime           @map("betted_at")
  betAmountInGameCurrency Decimal            @map("bet_amount_in_game_currency") @db.Decimal(32, 18)
  isCancelled             Boolean            @default(false) @map("is_cancelled")
  cancelledAt             DateTime?          @map("cancelled_at")
  gameRound               GameRound          @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  // 1. PK에 파티션 키 포함
  @@id([id, bettedAt])
  // 2. 유니크 제약조건에도 파티션 키 필수 (DB 물리적 제약)
  @@unique([aggregatorBetId, aggregatorType, bettedAt])
  @@index([gameRoundId, bettedAt])
  @@map("game_bets")
}

model GameWin {
  id                      BigInt
  userId                  BigInt             @map("user_id")
  gameRoundId             BigInt             @map("game_round_id")
  aggregatorType          GameAggregatorType @map("aggregator_type")
  aggregatorWinId         String             @map("aggregator_win_id")
  winType                 WinType            @map("win_type")
  winAmount               Decimal            @map("win_amount") @db.Decimal(32, 18)
  wonAt                   DateTime           @map("won_at")
  description             String?
  winAmountInGameCurrency Decimal            @map("win_amount_in_game_currency") @db.Decimal(32, 18)
  gameRound               GameRound          @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  // PK에 파티션 키(wonAt)를 포함시킵니다.
  @@id([id, wonAt])
  // 비즈니스 로직상 유니크 제약조건에도 파티션 키가 포함되어야 합니다.
  @@unique([aggregatorWinId, aggregatorType, wonAt])
  @@index([gameRoundId])
  @@map("game_wins")
}

// ═══════════════════════════════════════════════════════════════
// 신규 카지노 구조 (Refactored)
// ═══════════════════════════════════════════════════════════════

model CasinoAggregator {
  id   BigInt @id @default(autoincrement())
  name String @map("name") // 표기용 이름 (예: DC, W)
  code String @unique @map("code") // 시스템 식별 코드 (예: DC, WC)

  // 상태 관리 (Active, Inactive, Maintenance)
  status AggregatorStatus @map("status")

  // API 호출 활성화 여부
  apiEnabled Boolean @default(true) @map("api_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  providers CasinoGameProvider[]

  @@map("casino_aggregators")
}

model CasinoGameProvider {
  id           BigInt @id @default(autoincrement())
  aggregatorId BigInt @map("aggregator_id")

  // 식별 정보
  externalId String @map("external_id") // 애그리게이터 API 호출 시 사용하는 프로바이더 ID
  code       String @map("code") // 내부 식별 코드 (예: PRAGMATIC, EVO_KR, EVO_IN)
  groupCode  String @map("group_code") // 브랜드 통합 코드 (예: PRAGMATIC, EVOLUTION)

  name     String  @map("name") // 표기용 이름
  imageUrl String? @map("image_url") // 로고 이미지 URL

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  aggregator CasinoAggregator @relation(fields: [aggregatorId], references: [id])
  games      CasinoGameV2[]

  @@unique([aggregatorId, code])
  @@unique([aggregatorId, externalId]) // 애그리게이터 내 외부 ID 유니크
  @@map("casino_game_providers")
}

enum AggregatorStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ═══════════════════════════════════════════════════════════════
// 게임 카테고리 (통합 - PRIMARY/COLLECTION 타입으로 구분)
// ══════════════════════════════════════════════════════════════

model CasinoGameCategory {
  id   BigInt @id @default(autoincrement())
  code String @unique @map("code") // 식별 코드 (예: SLOTS, LIVE_CASINO, WEEKLY_HOT)

  type CategoryType @default(PRIMARY) @map("type") // PRIMARY: 게임 타입, COLLECTION: 마케팅 그룹

  iconUrl   String? @map("icon_url") // 카테고리 아이콘 URL
  bannerUrl String? @map("banner_url") // 배너 이미지 URL

  sortOrder Int     @default(0) @map("sort_order") // 정렬 순서 (값이 낮을수록 왼쪽부터 표시)
  isActive  Boolean @default(true) @map("is_active") // 활성화 여부
  isSystem  Boolean @default(false) @map("is_system") // 시스템 생성 (삭제 방지)

  // 자동 채우기 규칙 (스케줄러 연동 - COLLECTION 타입 전용)
  // autoPopulate Boolean @default(false) @map("auto_populate") // 자동 갱신 여부
  // autoRule     Json?   @map("auto_rule") // 자동 규칙 (예: {"type": "most_played", "period": "7d", "limit": 20})

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  gameItems    CasinoGameCategoryItem[]
  translations CasinoGameCategoryTranslation[]

  @@map("casino_game_categories")
}

model CasinoGameCategoryTranslation {
  id          BigInt   @id @default(autoincrement())
  categoryId  BigInt   @map("category_id")
  language    Language
  name        String   @map("name") // 번역된 카테고리 이름
  description String?  @map("description") // 번역된 설명

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category CasinoGameCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@map("casino_game_category_translations")
}

// N:M 중간 테이블 (카테고리 내 게임 - 순위 포함)
model CasinoGameCategoryItem {
  id         BigInt @id @default(autoincrement())
  categoryId BigInt @map("category_id")
  gameId     BigInt @map("game_id")

  sortOrder Int     @default(0) @map("sort_order") // 카테고리 내에서의 순위
  isPrimary Boolean @default(false) @map("is_primary") // 게임의 기본 카테고리 여부 (삭제 방지)

  addedAt   DateTime  @default(now()) @map("added_at") // 추가 일시
  expiresAt DateTime? @map("expires_at") // 만료 일시 (프로모션/기간한정용)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category CasinoGameCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  game     CasinoGameV2       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([categoryId, gameId]) // 같은 게임은 같은 카테고리에 중복 불가
  @@index([categoryId, sortOrder]) // 카테고리별 정렬 조회 최적화
  @@index([gameId, isPrimary]) // 게임의 기본 카테고리 조회
  @@index([expiresAt]) // 만료 체크용
  @@map("casino_game_category_items")
}

enum CategoryType {
  PRIMARY // 게임의 본질적 타입 (슬롯, 라이브, 테이블)
  COLLECTION // 운영/마케팅 목적 그룹 (주간 인기, 신규, 프로모션)
}

// ═══════════════════════════════════════════════════════════════
// 게임 (Refactored - N:M 카테고리 관계)
// ═══════════════════════════════════════════════════════════════

model CasinoGameV2 {
  id         BigInt @id @default(autoincrement())
  providerId BigInt @map("provider_id")

  // 게임 식별 정보 (애그리게이터에서 제공하는 원본 값)
  externalGameId String @map("external_game_id") // 애그리게이터에서 제공하는 게임 ID
  code           String @map("code") // 게임 코드 (예: pragmatic_gates_of_olympus)

  // 이미지
  thumbnailUrl String? @map("thumbnail_url") // 썸네일 이미지 URL
  bannerUrl    String? @map("banner_url") // 배너 이미지 URL (선택)

  // 게임 속성
  rtp        Decimal? @map("rtp") @db.Decimal(5, 2) // Return To Player % (예: 96.50 = 96.50%)
  volatility String?  @map("volatility") // LOW, MEDIUM, HIGH, VERY_HIGH
  gameType   String?  @map("game_type") // 상세 타입 (예: video_slots, classic_slots)
  tableId    String?  @map("table_id") // 라이브 게임의 경우 테이블 ID
  tags       String[] @map("tags") // 관리자 지정 태그 (예: ["jackpot", "megaways", "bonus_buy"])

  // 베팅/운영 정보
  houseEdge        Decimal @default(0.04) @map("house_edge") @db.Decimal(8, 4) // 하우스 엣지
  contributionRate Decimal @default(1.0) @map("contribution_rate") @db.Decimal(8, 4) // 롤링 기여율

  // 표시/정렬
  sortOrder Int     @default(0) @map("sort_order") // 전역 정렬 순서
  isEnabled Boolean @default(true) @map("is_enabled") // 관리자 활성화 (운영 제어)
  isVisible Boolean @default(true) @map("is_visible") // 사용자 노출 여부

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  provider      CasinoGameProvider        @relation(fields: [providerId], references: [id])
  translations  CasinoGameV2Translation[]
  categoryItems CasinoGameCategoryItem[] // N:M 카테고리 관계

  @@unique([providerId, externalGameId]) // 프로바이더 + 외부게임ID 조합은 유니크
  @@index([isEnabled, isVisible])
  @@index([sortOrder])
  @@map("casino_games_v2")
}

model CasinoGameV2Translation {
  id       BigInt   @id @default(autoincrement())
  gameId   BigInt   @map("game_id")
  language Language
  name     String   @map("name") // 번역된 게임 이름

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game CasinoGameV2 @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, language])
  @@index([language])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("casino_game_v2_translations")
}
