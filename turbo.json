{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "db:generate"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "out/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "test": {
            "dependsOn": [],
            "outputs": []
        },
        "format": {
            "dependsOn": [],
            "outputs": []
        }
    }
}